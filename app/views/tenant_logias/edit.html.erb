<% t_sub = @tenant.t_logia %>
<% content_for(:title, "Editar #{@logia.nombre} — #{@tenant.nombre_display}") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-0"><i class="bi bi-pencil me-2"></i><%= @logia.nombre %></h1>
    <small class="text-muted"><%= t_sub %> de <strong><%= @tenant.nombre_display %></strong></small>
  </div>
  <%= link_to tenant_path(@tenant), class: "btn btn-outline-secondary btn-sm" do %>
    <i class="bi bi-arrow-left me-1"></i>Volver
  <% end %>
</div>

<div class="card">
  <div class="card-body">
    <%= render "form", logia: @logia %>
  </div>
</div>
