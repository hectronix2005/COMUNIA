<%
  viewer = begin current_user rescue nil end
  propio = viewer && mensaje.user_id == viewer.id
  continuacion = local_assigns[:continuacion]
  color = mensaje.user.miembro&.logia&.color_display || "#6c757d"
  sender_display = mensaje.user.nombre_chat
  sender_initials = sender_display.split(/\s+/).first(2).map { |p| p[0].to_s.upcase }.join.presence || "?"
%>
<div class="msg-row <%= propio ? 'msg-row--own' : '' %> <%= continuacion ? '' : 'msg-row--group-start' %>"
     id="mensaje_<%= mensaje.id %>">

  <%# Avatar (only for others, only on group start) %>
  <% unless propio %>
    <% if continuacion %>
      <div style="width:28px;flex-shrink:0;margin-right:4px;"></div>
    <% else %>
      <div class="chat-avatar chat-avatar-sm flex-shrink-0" style="background:<%= color %>;align-self:flex-end;margin-right:4px;">
        <%= sender_initials %>
      </div>
    <% end %>
  <% end %>

  <div class="msg-bubble <%= propio ? 'msg-bubble--own' : 'msg-bubble--other' %>"
       data-controller="chat-reaction" data-chat-reaction-id-value="<%= mensaje.id %>">

    <%# Sender name (only for others, only on group start, only in channels) %>
    <% if !propio && !continuacion && !mensaje.dm? %>
      <div class="msg-sender" style="color:<%= color %>;">
        <%= sender_display %>
      </div>
    <% end %>

    <%# Content + inline time (WhatsApp style) %>
    <span class="msg-content"><%= mensaje.contenido %></span>
    <span class="msg-meta-inline">
      <span class="msg-time"><%= mensaje.created_at.strftime("%H:%M") %></span>
      <% if propio && mensaje.dm? %>
        <% if mensaje.leido? %>
          <i class="bi bi-check2-all msg-check msg-check--read"></i>
        <% else %>
          <i class="bi bi-check2-all msg-check msg-check--sent"></i>
        <% end %>
      <% end %>
    </span>

    <%# Emoji reaction trigger (shows on hover) %>
    <span class="emoji-picker-trigger" data-action="click->chat-reaction#showPicker">
      <i class="bi bi-chevron-down"></i>
    </span>
    <div class="emoji-picker" data-chat-reaction-target="picker">
      <% ChatMensaje::REACCIONES_PERMITIDAS.each do |e| %>
        <span style="cursor:pointer;font-size:1.1rem;padding:0 3px;"
              data-action="click->chat-reaction#react"
              data-emoji="<%= e %>"><%= e %></span>
      <% end %>
    </div>
  </div>
</div>

<%# Reactions bar %>
<div id="msg-reacciones-<%= mensaje.id %>">
  <%= render "chat/mensaje_reacciones", mensaje: mensaje %>
</div>
