<% content_for(:title, "Chat — #{current_logia.nombre_display}") %>
<% content_for :head do %>
  <style>
    .chat-layout       { display:flex; height:calc(100vh - 140px); gap:0; border:1px solid #dee2e6; border-radius:.5rem; overflow:hidden; background:#fff; }
    .chat-sidebar      { width:290px; min-width:230px; border-right:1px solid #dee2e6; display:flex; flex-direction:column; background:#f8f9fa; }
    .chat-sidebar-head { padding:.55rem 1rem; font-weight:700; font-size:.74rem; text-transform:uppercase; letter-spacing:.07em; color:#6c757d; border-bottom:1px solid #dee2e6; background:#f0f1f3; }
    .chat-sidebar-list { flex:1; overflow-y:auto; }
    .chat-item         { display:flex; align-items:center; gap:.6rem; padding:.55rem 1rem; cursor:pointer; border-bottom:1px solid #f0f0f0; text-decoration:none; color:inherit; transition:background .12s; }
    .chat-item:hover   { background:#e9ecef; }
    .chat-item.active  { background:#1B2A4A; color:#fff; }
    .chat-item.active .text-muted  { color:rgba(255,255,255,.65) !important; }
    .chat-item.active .badge-logia { background:rgba(255,255,255,.2) !important; color:#fff !important; }
    .chat-avatar       { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.72rem; font-weight:700; flex-shrink:0; }
    .chat-main         { flex:1; display:flex; flex-direction:column; min-width:0; }
    .chat-main-head    { padding:.75rem 1rem; border-bottom:1px solid #dee2e6; display:flex; align-items:center; gap:.75rem; background:#fff; }
    .chat-mensajes     { flex:1; overflow-y:auto; padding:1rem; }
    .chat-input-area   { padding:.75rem 1rem; border-top:1px solid #dee2e6; background:#fff; }
    .badge-logia       { font-size:.62rem; padding:.18em .45em; border-radius:.3rem; background:#e9ecef; color:#495057; font-weight:600; }
  </style>
<% end %>

<%= turbo_stream_from @stream %>

<div class="chat-layout">

  <%# ── Sidebar ──────────────────────────────────────────── %>
  <div class="chat-sidebar">
    <div class="chat-sidebar-list">

      <%# ── CANALES ── %>
      <div class="chat-sidebar-head"><i class="bi bi-hash me-1"></i>Canales</div>

      <%# Canal Tenant %>
      <%= link_to chat_path, class: "chat-item #{@canal == 'tenant' ? 'active' : ''}" do %>
        <div class="chat-avatar" style="background:#1B2A4A;color:#fff;">
          <i class="bi bi-globe2" style="font-size:.85rem;"></i>
        </div>
        <div class="min-w-0">
          <div class="fw-semibold" style="font-size:.87rem;">Todo el Tenant</div>
          <div class="text-muted" style="font-size:.7rem;"><%= current_logia.tenant_id.nil? ? current_logia.nombre_display : Logia.find(current_logia.tenant_id).nombre_display rescue current_logia.nombre_display %></div>
        </div>
      <% end %>

      <%# Canal de la Logia propia %>
      <%= link_to chat_path(canal: "logia"), class: "chat-item #{@canal == 'logia' ? 'active' : ''}" do %>
        <div class="chat-avatar" style="background:<%= current_logia.color_display || '#6c757d' %>;color:#fff;">
          <i class="bi bi-building" style="font-size:.85rem;"></i>
        </div>
        <div class="min-w-0">
          <div class="fw-semibold" style="font-size:.87rem;"><%= current_logia.nombre_display %></div>
          <div class="text-muted" style="font-size:.7rem;">Solo miembros de esta logia</div>
        </div>
      <% end %>

      <%# ── MENSAJES DIRECTOS ── %>
      <div class="chat-sidebar-head mt-0">
        <i class="bi bi-person me-1"></i>Mensajes directos
        <span class="float-end text-muted fw-normal" style="font-size:.72rem;text-transform:none;letter-spacing:0;"><%= @miembros_chat.size %></span>
      </div>

      <% @miembros_chat.each do |u| %>
        <%
          u_display  = u.nombre_chat
          u_initials = u_display.split(/\s+/).first(2).map { |p| p[0].to_s.upcase }.join.presence || "?"
        %>
        <%= link_to chat_path(con: u.id), class: "chat-item #{@canal == 'dm' && @con_id == u.id ? 'active' : ''}" do %>
          <div class="chat-avatar" style="background:<%= u.miembro&.logia&.color_display || '#6c757d' %>;color:#fff;">
            <%= u_initials %>
          </div>
          <div class="min-w-0" style="overflow:hidden;">
            <div class="fw-semibold text-truncate" style="font-size:.85rem;"><%= u_display %></div>
            <div class="text-muted text-truncate" style="font-size:.7rem;">
              <span class="badge-logia"><%= u.miembro&.logia&.nombre || "—" %></span>
            </div>
          </div>
        <% end %>
      <% end %>

      <div class="chat-sidebar-head mt-0">
        <i class="bi bi-gear me-1"></i>Perfil
      </div>
      <%= link_to perfil_path, class: "chat-item" do %>
        <div class="chat-avatar" style="background:#6c757d;color:#fff;">
          <i class="bi bi-pencil" style="font-size:.85rem;"></i>
        </div>
        <div class="min-w-0" style="overflow:hidden;">
          <div class="fw-semibold text-truncate" style="font-size:.85rem;">Mi nombre en el chat</div>
          <div class="text-muted text-truncate" style="font-size:.7rem;"><%= current_user.nombre_chat %></div>
        </div>
      <% end %>

    </div>
  </div>

  <%# ── Panel principal ──────────────────────────────────── %>
  <div class="chat-main">

    <%# Header %>
    <div class="chat-main-head">
      <% if @canal == "dm" && @destinatario %>
        <%
          dest_display  = @destinatario.nombre_chat
          dest_initials = dest_display.split(/\s+/).first(2).map { |p| p[0].to_s.upcase }.join.presence || "?"
        %>
        <div class="chat-avatar" style="width:38px;height:38px;background:<%= @destinatario.miembro&.logia&.color_display || '#6c757d' %>;color:#fff;">
          <%= dest_initials %>
        </div>
        <div>
          <div class="fw-bold"><%= dest_display %></div>
          <div class="text-muted small"><i class="bi bi-building me-1"></i><%= @destinatario.miembro&.logia&.nombre %></div>
        </div>
        <span class="badge ms-auto" style="background:#6f42c1;">
          <i class="bi bi-lock me-1"></i>Privado
        </span>

      <% elsif @canal == "logia" %>
        <div class="chat-avatar" style="width:38px;height:38px;background:<%= current_logia.color_display || '#6c757d' %>;color:#fff;">
          <i class="bi bi-building"></i>
        </div>
        <div>
          <div class="fw-bold"><%= current_logia.nombre_display %></div>
          <div class="text-muted small">Solo miembros de esta logia</div>
        </div>
        <span class="badge ms-auto" style="background:<%= current_logia.color_display || '#6c757d' %>;">
          <i class="bi bi-building me-1"></i>Logia
        </span>

      <% else %>
        <div class="chat-avatar" style="width:38px;height:38px;background:#1B2A4A;color:#fff;">
          <i class="bi bi-globe2"></i>
        </div>
        <div>
          <div class="fw-bold">Canal General del Tenant</div>
          <div class="text-muted small">Todos los miembros del tenant</div>
        </div>
        <span class="badge ms-auto" style="background:#1B2A4A;">
          <i class="bi bi-globe2 me-1"></i>Tenant
        </span>
      <% end %>
    </div>

    <%# Mensajes %>
    <div class="chat-mensajes" id="chat-mensajes-wrapper">
      <div id="chat-mensajes">
        <% if @mensajes.empty? %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-chat-square-text fs-2 d-block mb-2"></i>
            <% if @canal == "dm" %>
              Inicia una conversaci&oacute;n privada con <strong><%= @destinatario.nombre_chat %></strong>
            <% elsif @canal == "logia" %>
              No hay mensajes aún en el canal de <strong><%= current_logia.nombre_display %></strong>
            <% else %>
              No hay mensajes aún en el canal general del tenant.
            <% end %>
          </div>
        <% else %>
          <% @mensajes.each do |m| %>
            <%= render "chat/mensaje", mensaje: m %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Input %>
    <div class="chat-input-area">
      <% form_url = @canal == "dm" ? chat_path(con: @con_id) : chat_path(canal: @canal) %>
      <%= form_with url: form_url,
            method: :post,
            data: { controller: "chat-form", action: "submit->chat-form#submit", turbo: false },
            class: "d-flex gap-2" do |f| %>
        <%= f.text_field :contenido,
              id: "chat-input",
              class: "form-control",
              placeholder: @canal == "dm" ? "Mensaje privado a #{@destinatario.nombre_chat}..." :
                           @canal == "logia" ? "Mensaje en #{current_logia.nombre_display}..." :
                           "Mensaje al canal general del tenant...",
              autocomplete: "off",
              maxlength: 1000,
              data: { "chat-form-target": "input" } %>
        <button type="submit" class="btn btn-primary px-3" style="background:#1B2A4A;border-color:#1B2A4A;">
          <i class="bi bi-send-fill"></i>
        </button>
      <% end %>
    </div>

  </div><%# /chat-main %>
</div><%# /chat-layout %>

<script>
  (function() {
    var w = document.getElementById('chat-mensajes-wrapper');
    if (!w) return;
    w.scrollTop = w.scrollHeight;
    new MutationObserver(function() { w.scrollTop = w.scrollHeight; })
      .observe(w, { childList: true, subtree: true });
  })();
</script>
