<% content_for(:title, "Chat — #{current_logia.nombre_display}") %>
<% content_for :head do %>
  <style>
    /* ── Layout ── */
    .chat-layout { display:flex; height:calc(100vh - 140px); border:1px solid #dee2e6; border-radius:.5rem; overflow:hidden; background:#fff; }
    .chat-sidebar { width:320px; min-width:260px; border-right:1px solid #dee2e6; display:flex; flex-direction:column; background:#fff; }
    .chat-main { flex:1; display:flex; flex-direction:column; min-width:0; background:#e5ddd5; }
    .chat-main-head { padding:.6rem 1rem; border-bottom:1px solid #dee2e6; display:flex; align-items:center; gap:.6rem; background:#f0f2f5; }
    .chat-mensajes { flex:1; overflow-y:auto; padding:.75rem; }
    .chat-input-area { padding:.6rem 1rem; background:#f0f2f5; border-top:1px solid #dee2e6; }

    /* ── Sidebar ── */
    .chat-sidebar-head { padding:.5rem .8rem; font-weight:700; font-size:.7rem; text-transform:uppercase; letter-spacing:.06em; color:#667781; border-bottom:1px solid #e9edef; background:#f0f2f5; }
    .chat-sidebar-search { padding:.5rem; background:#f0f2f5; border-bottom:1px solid #e9edef; }
    .chat-sidebar-list { flex:1; overflow-y:auto; }
    .chat-item { display:flex; align-items:center; gap:.7rem; padding:.65rem .8rem; cursor:pointer; border-bottom:1px solid #f0f0f0; text-decoration:none; color:inherit; transition:background .12s; }
    .chat-item:hover { background:#f5f6f6; }
    .chat-item.active { background:#f0f2f5; }

    /* ── Avatars ── */
    .chat-avatar { width:44px; height:44px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.8rem; font-weight:700; flex-shrink:0; position:relative; }
    .chat-avatar-sm { width:28px; height:28px; font-size:.6rem; }
    .online-dot { width:10px; height:10px; background:#25d366; border-radius:50%; border:2px solid #fff; position:absolute; bottom:1px; right:1px; }

    /* ── Bubbles ── */
    .msg-row { display:flex; margin-bottom:2px; padding:0 4%; }
    .msg-row--own { justify-content:flex-end; }
    .msg-row--group-start { margin-top:10px; }
    .msg-bubble { max-width:70%; padding:5px 8px 2px; border-radius:8px; position:relative; word-break:break-word; font-size:.88rem; line-height:1.35; box-shadow:0 1px 0.5px rgba(0,0,0,.13); }
    .msg-bubble--own { background:#d9fdd3; border-top-right-radius:0; }
    .msg-bubble--other { background:#fff; border-top-left-radius:0; }
    .msg-sender { font-size:.75rem; font-weight:600; margin-bottom:1px; }
    .msg-meta { display:flex; justify-content:flex-end; align-items:center; gap:3px; margin-top:1px; }
    .msg-time { font-size:.65rem; color:#667781; }
    .msg-check { font-size:.7rem; }
    .msg-check--read { color:#53bdeb; }
    .msg-check--sent { color:#8696a0; }

    /* ── Date Separator ── */
    .chat-date-sep { text-align:center; margin:12px 0 8px; }
    .chat-date-sep span { background:#e1f3fb; color:#4a6878; font-size:.72rem; padding:4px 14px; border-radius:8px; box-shadow:0 1px 0.5px rgba(0,0,0,.13); }

    /* ── Reactions ── */
    .msg-reacciones { display:flex; gap:2px; flex-wrap:wrap; margin-top:2px; }
    .msg-reaccion { font-size:.7rem; padding:1px 5px; border-radius:10px; background:#f0f2f5; border:1px solid #e0e0e0; cursor:pointer; transition:background .15s; }
    .msg-reaccion:hover { background:#d9fdd3; }
    .msg-reaccion--active { background:#d9fdd3; border-color:#25d366; }
    .emoji-picker { display:none; position:absolute; top:-30px; right:0; background:#fff; border:1px solid #e0e0e0; border-radius:20px; padding:2px 6px; box-shadow:0 2px 8px rgba(0,0,0,.15); z-index:10; white-space:nowrap; }
    .msg-row:hover .emoji-picker-trigger { opacity:1; }
    .emoji-picker-trigger { opacity:0; transition:opacity .15s; cursor:pointer; font-size:.85rem; position:absolute; top:2px; }
    .msg-row--own .emoji-picker-trigger { left:-26px; }
    .msg-row:not(.msg-row--own) .emoji-picker-trigger { right:-26px; }

    /* ── Typing ── */
    .typing-indicator { animation:fadeIn .2s; padding:2px 0; }
    @keyframes fadeIn { from{opacity:0} to{opacity:1} }

    /* ── Unread badge ── */
    .unread-badge { background:#25d366; color:#fff; font-size:.65rem; min-width:18px; height:18px; padding:0 5px; border-radius:9px; display:flex; align-items:center; justify-content:center; font-weight:700; }

    /* ── Search ── */
    .chat-search-overlay { position:absolute; top:0; right:0; width:100%; max-width:360px; height:100%; background:#fff; z-index:20; border-left:1px solid #dee2e6; display:flex; flex-direction:column; }

    /* ── Mobile: full-screen panels ── */
    .chat-back-btn { display:none !important; }
    @media (max-width: 768px) {
      .chat-sidebar { width:100% !important; min-width:0; border-right:none; }
      .chat-main { display:none; width:100%; }
      .chat-layout--open .chat-sidebar { display:none; }
      .chat-layout--open .chat-main { display:flex; }
      .chat-back-btn { display:inline-flex !important; }
      .chat-search-overlay { max-width:100%; }
    }

    /* ── DM search ── */
    .dm-hidden { display:none; }
    .dm-searching .dm-hidden { display:flex; }
    .dm-searching .dm-item.dm-no-match { display:none !important; }

    /* ── Input ── */
    .chat-textarea { resize:none; max-height:120px; overflow-y:auto; border-radius:8px; font-size:.9rem; }
  </style>
<% end %>

<%= turbo_stream_from @stream %>

<div class="chat-layout <%= 'chat-layout--open' if @canal == 'dm' && @con_id || @canal != 'tenant' && params[:canal].present? %>">

  <%# ══════════════ SIDEBAR ══════════════ %>
  <div class="chat-sidebar">

    <%# Search bar %>
    <div class="chat-sidebar-search">
      <div class="position-relative">
        <i class="bi bi-search position-absolute" style="left:10px;top:50%;transform:translateY(-50%);color:#adb5bd;font-size:.78rem;"></i>
        <input type="text" id="dm-search" class="form-control form-control-sm"
               placeholder="Buscar miembro..."
               autocomplete="off" style="padding-left:30px;font-size:.8rem;border-radius:8px;background:#f0f2f5;border-color:#e9edef;">
      </div>
    </div>

    <div class="chat-sidebar-list" id="dm-list">

      <%# ── CHANNELS ── %>
      <div class="chat-sidebar-head"><i class="bi bi-hash me-1"></i>Canales</div>

      <%= link_to chat_path, class: "chat-item #{@canal == 'tenant' ? 'active' : ''}" do %>
        <div class="chat-avatar" style="background:#1B2A4A;color:#fff;">
          <i class="bi bi-globe2" style="font-size:.95rem;"></i>
        </div>
        <div class="flex-grow-1 min-w-0">
          <div class="d-flex justify-content-between">
            <span class="fw-semibold text-truncate" style="font-size:.88rem;">Canal General</span>
          </div>
          <div class="text-muted text-truncate" style="font-size:.75rem;">Todos los miembros</div>
        </div>
      <% end %>

      <%= link_to chat_path(canal: "logia"), class: "chat-item #{@canal == 'logia' ? 'active' : ''}" do %>
        <div class="chat-avatar" style="background:<%= current_logia.color_display || '#6c757d' %>;color:#fff;">
          <i class="bi bi-building" style="font-size:.95rem;"></i>
        </div>
        <div class="flex-grow-1 min-w-0">
          <div class="d-flex justify-content-between">
            <span class="fw-semibold text-truncate" style="font-size:.88rem;"><%= current_logia.nombre_display %></span>
          </div>
          <div class="text-muted text-truncate" style="font-size:.75rem;">Solo esta logia</div>
        </div>
      <% end %>

      <%# ── DIRECT MESSAGES ── %>
      <div class="chat-sidebar-head"><i class="bi bi-chat-dots me-1"></i>Mensajes directos</div>

      <%# Recent DMs first %>
      <% dm_shown_ids = [] %>
      <% sorted_recientes = (@dm_recientes || []).sort_by { |u| -(@ultimo_dm[u.id]&.created_at&.to_i || 0) } %>
      <% sorted_recientes.each do |u| %>
        <% dm_shown_ids << u.id %>
        <%= render "chat/sidebar_dm_item", u: u, ultimo: @ultimo_dm[u.id], unread: @unread_counts[u.id] || 0, activo: (@canal == 'dm' && @con_id == u.id) %>
      <% end %>

      <%# All other members (hidden, shown on search) %>
      <% (@miembros_chat - (@dm_recientes || [])).each do |u| %>
        <%= render "chat/sidebar_dm_item", u: u, ultimo: @ultimo_dm[u.id], unread: @unread_counts[u.id] || 0, activo: (@canal == 'dm' && @con_id == u.id), hidden: !dm_shown_ids.include?(u.id) %>
      <% end %>

      <div id="dm-no-results" class="text-center text-muted py-3 d-none" style="font-size:.8rem;">
        <i class="bi bi-search me-1"></i>Sin resultados
      </div>

    </div>
  </div>

  <%# ══════════════ MAIN CHAT ══════════════ %>
  <div class="chat-main" style="position:relative;">

    <%# Header %>
    <div class="chat-main-head">
      <a href="<%= chat_path %>" class="chat-back-btn btn btn-sm btn-light me-1">
        <i class="bi bi-arrow-left"></i>
      </a>

      <% if @canal == "dm" && @destinatario %>
        <%
          dest_display  = @destinatario.nombre_chat
          dest_initials = dest_display.split(/\s+/).first(2).map { |p| p[0].to_s.upcase }.join.presence || "?"
        %>
        <div class="chat-avatar" style="background:<%= @destinatario.miembro&.logia&.color_display || '#6c757d' %>;color:#fff;">
          <%= dest_initials %>
          <% if @destinatario.online? %><span class="online-dot"></span><% end %>
        </div>
        <div class="flex-grow-1 min-w-0">
          <div class="fw-bold" style="font-size:.92rem;"><%= dest_display %></div>
          <div style="font-size:.72rem;">
            <% if @destinatario.online? %>
              <span class="text-success">en línea</span>
            <% elsif @destinatario.last_seen_at %>
              <span class="text-muted">últ. vez <%= time_ago_in_words(@destinatario.last_seen_at) %></span>
            <% else %>
              <span class="text-muted"><%= @destinatario.miembro&.logia&.nombre %></span>
            <% end %>
          </div>
        </div>

      <% elsif @canal == "logia" %>
        <div class="chat-avatar" style="background:<%= current_logia.color_display || '#6c757d' %>;color:#fff;">
          <i class="bi bi-building"></i>
        </div>
        <div class="flex-grow-1">
          <div class="fw-bold" style="font-size:.92rem;"><%= current_logia.nombre_display %></div>
          <div class="text-muted" style="font-size:.72rem;">Solo miembros de esta logia</div>
        </div>

      <% else %>
        <div class="chat-avatar" style="background:#1B2A4A;color:#fff;">
          <i class="bi bi-globe2"></i>
        </div>
        <div class="flex-grow-1">
          <div class="fw-bold" style="font-size:.92rem;">Canal General</div>
          <div class="text-muted" style="font-size:.72rem;">Todos los miembros del tenant</div>
        </div>
      <% end %>

      <button class="btn btn-sm btn-light ms-auto" data-action="click->chat-search#toggle" data-chat-search-target="toggleBtn" title="Buscar">
        <i class="bi bi-search"></i>
      </button>
    </div>

    <%# Messages area %>
    <div class="chat-mensajes" id="chat-mensajes-wrapper" data-controller="chat-search"
         data-chat-search-canal-value="<%= @canal %>"
         data-chat-search-con-value="<%= @con_id %>">
      <div id="chat-mensajes">
        <% if @mensajes.blank? %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-chat-square-text fs-2 d-block mb-2 opacity-50"></i>
            <% if @canal == "dm" %>
              <span style="font-size:.88rem;">Inicia una conversación con <strong><%= @destinatario.nombre_chat %></strong></span>
            <% else %>
              <span style="font-size:.88rem;">No hay mensajes aún</span>
            <% end %>
          </div>
        <% else %>
          <% prev_date = nil; prev_user = nil; prev_time = nil %>
          <% @mensajes.each do |m| %>
            <% msg_date = m.created_at.to_date %>
            <% if msg_date != prev_date %>
              <div class="chat-date-sep">
                <span>
                  <% if msg_date == Date.current %>Hoy
                  <% elsif msg_date == Date.yesterday %>Ayer
                  <% else %><%= I18n.l(msg_date, format: :long) rescue msg_date.strftime("%d/%m/%Y") %>
                  <% end %>
                </span>
              </div>
              <% prev_date = msg_date; prev_user = nil %>
            <% end %>
            <% continuacion = (prev_user == m.user_id && prev_time && (m.created_at - prev_time) < 120) %>
            <%= render "chat/mensaje", mensaje: m, continuacion: continuacion %>
            <% prev_user = m.user_id; prev_time = m.created_at %>
          <% end %>
        <% end %>
      </div>
      <div id="chat-typing"></div>

      <%# Search overlay %>
      <div class="chat-search-overlay" data-chat-search-target="overlay" style="display:none;">
        <div class="d-flex align-items-center gap-2 p-2 border-bottom" style="background:#f0f2f5;">
          <button class="btn btn-sm btn-light" data-action="click->chat-search#toggle"><i class="bi bi-x-lg"></i></button>
          <input type="text" class="form-control form-control-sm" placeholder="Buscar mensajes..."
                 data-chat-search-target="input" data-action="input->chat-search#search"
                 style="border-radius:8px;">
        </div>
        <div class="flex-grow-1 overflow-auto" data-chat-search-target="results">
        </div>
      </div>
    </div>

    <%# Input area %>
    <div class="chat-input-area">
      <% form_url = @canal == "dm" ? chat_path(con: @con_id) : chat_path(canal: @canal) %>
      <%= form_with url: form_url,
            method: :post,
            data: { controller: "chat-form", action: "submit->chat-form#submit", turbo: false, stream: @stream },
            class: "d-flex gap-2 align-items-end" do |f| %>

        <%# Emoji button %>
        <div class="position-relative" data-controller="emoji-picker">
          <button type="button" class="btn btn-sm btn-light" style="border-radius:50%;width:36px;height:36px;"
                  data-action="click->emoji-picker#toggle">
            <i class="bi bi-emoji-smile" style="font-size:1.1rem;color:#667781;"></i>
          </button>
          <div class="position-absolute bottom-100 start-0 mb-1 bg-white rounded-3 shadow border p-2"
               style="display:none;z-index:20;" data-emoji-picker-target="panel">
            <% ChatMensaje::REACCIONES_PERMITIDAS.each do |e| %>
              <span style="cursor:pointer;font-size:1.3rem;padding:2px 4px;"
                    data-action="click->emoji-picker#insert"
                    data-emoji="<%= e %>"><%= e %></span>
            <% end %>
          </div>
        </div>

        <textarea id="chat-input" rows="1" name="contenido"
              class="form-control chat-textarea"
              placeholder="<%= @canal == 'dm' ? "Mensaje a #{@destinatario&.nombre_chat}..." : 'Escribe un mensaje...' %>"
              autocomplete="off" maxlength="1000"
              data-chat-form-target="input"
              data-action="keydown->chat-form#keydown input->chat-form#autoResize input->chat-form#sendTyping"></textarea>

        <button type="submit" class="btn btn-primary" style="background:#25d366;border-color:#25d366;border-radius:50%;width:38px;height:38px;flex-shrink:0;">
          <i class="bi bi-send-fill"></i>
        </button>
      <% end %>
    </div>

  </div>
</div>

<script>
(function() {
  // Auto-scroll
  var w = document.getElementById('chat-mensajes-wrapper');
  if (w) {
    w.scrollTop = w.scrollHeight;
    new MutationObserver(function() { w.scrollTop = w.scrollHeight; })
      .observe(document.getElementById('chat-mensajes'), { childList: true, subtree: true });
  }

  // DM sidebar search
  var searchInput = document.getElementById('dm-search');
  var dmList = document.getElementById('dm-list');
  var noResults = document.getElementById('dm-no-results');
  if (searchInput && dmList) {
    searchInput.addEventListener('input', function() {
      var q = this.value.toLowerCase().trim();
      var items = dmList.querySelectorAll('.dm-item');
      if (q === '') {
        dmList.classList.remove('dm-searching');
        items.forEach(function(el) { el.classList.remove('dm-no-match'); });
        noResults.classList.add('d-none');
        return;
      }
      dmList.classList.add('dm-searching');
      var found = 0;
      items.forEach(function(el) {
        var nombre = el.dataset.nombre || '';
        var match = nombre.indexOf(q) !== -1;
        el.classList.toggle('dm-no-match', !match);
        if (match) found++;
      });
      noResults.classList.toggle('d-none', found > 0);
    });
  }

  // Auto-remove typing indicators after 3s
  new MutationObserver(function(mutations) {
    mutations.forEach(function(m) {
      m.addedNodes.forEach(function(n) {
        if (n.classList && n.classList.contains('typing-indicator')) {
          setTimeout(function() { n.remove(); }, 3000);
        }
      });
    });
  }).observe(document.getElementById('chat-typing') || document.body, { childList: true });
})();
</script>
