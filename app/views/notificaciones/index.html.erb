<turbo-frame id="notificaciones-lista">
  <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom" style="background:#f8f9fa;">
    <strong class="small">Notificaciones</strong>
    <% if @notificaciones.any? { |n| !n.leida } %>
      <%= button_to leer_todas_notificaciones_path, method: :post,
            class: "btn btn-link btn-sm p-0 text-decoration-none", style: "font-size:.72rem;" do %>
        Marcar todas leídas
      <% end %>
    <% end %>
  </div>

  <div class="list-group list-group-flush" style="max-height:340px;overflow-y:auto;">
    <% if @notificaciones.empty? %>
      <div class="text-center text-muted py-4">
        <i class="bi bi-bell-slash d-block mb-1" style="font-size:1.5rem;opacity:.4;"></i>
        <span style="font-size:.82rem;">Sin notificaciones</span>
      </div>
    <% else %>
      <% @notificaciones.each do |n| %>
        <% icon, color = case n.tipo
            when "chat_dm"    then ["bi-chat-dots-fill", "#6f42c1"]
            when "chat_canal" then ["bi-megaphone-fill", "#1B2A4A"]
            when "cumpleanos" then ["bi-balloon-heart-fill", "#fd7e14"]
            else ["bi-bell-fill", "#6c757d"]
           end
        %>
        <a href="<%= n.url || '#' %>"
           class="list-group-item list-group-item-action d-flex gap-2 py-2 px-3 <%= n.leida ? '' : 'bg-light' %>"
           data-action="click->notifications#markRead"
           data-notification-id="<%= n.id %>"
           style="font-size:.83rem;border-left:3px solid <%= n.leida ? 'transparent' : color %>;">
          <i class="bi <%= icon %> flex-shrink-0 mt-1" style="color:<%= color %>;"></i>
          <div class="min-w-0 flex-grow-1">
            <div class="fw-semibold text-truncate"><%= n.titulo %></div>
            <% if n.cuerpo.present? %>
              <div class="text-muted text-truncate" style="font-size:.75rem;"><%= n.cuerpo %></div>
            <% end %>
            <div class="text-muted" style="font-size:.68rem;">
              <%= time_ago_in_words(n.created_at) %>
            </div>
          </div>
          <% unless n.leida %>
            <span class="align-self-center flex-shrink-0">
              <span class="rounded-circle d-inline-block bg-danger" style="width:8px;height:8px;"></span>
            </span>
          <% end %>
        </a>
      <% end %>
    <% end %>
  </div>
</turbo-frame>
