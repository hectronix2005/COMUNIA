<% activos_count = @logia.miembros.activos.count %>
<% suma_otros = @logia.suma_conceptos_sin(@concepto) %>

<%= form_with(model: [@logia, @concepto], class: "row g-3") do |f| %>
  <% if @concepto.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @concepto.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="col-md-6">
    <%= f.label :nombre, "Nombre del Concepto", class: "form-label" %>
    <%= f.text_field :nombre, class: "form-control", required: true,
        placeholder: "Ej: Aporte Gran Logia, Arriendo Templo, Aporte Tesoro..." %>
  </div>

  <div class="col-md-3">
    <%= f.label :tipo, "Tipo de Cobro", class: "form-label" %>
    <%= f.select :tipo,
        [
          ["Fijo por miembro", "por_miembro"],
          ["Fijo por logia (dividido)", "por_logia"],
          ["Complemento (cuota total)", "complemento"]
        ],
        {},
        class: "form-select", id: "concepto-tipo",
        onchange: "actualizarTipo()" %>
  </div>

  <div class="col-md-3">
    <%= f.label :orden, "Orden", class: "form-label" %>
    <%= f.number_field :orden, class: "form-control", min: 0, value: @concepto.orden || 0 %>
  </div>

  <div class="col-md-4">
    <%= f.label :monto, class: "form-label" do %>
      <span id="monto-label">
        <% if @concepto.complemento? %>
          Cuota Per C&aacute;pita Total
        <% elsif @concepto.por_logia? %>
          Monto Total de la Logia
        <% else %>
          Monto por Miembro
        <% end %>
      </span>
    <% end %>
    <div class="input-group">
      <span class="input-group-text">$</span>
      <%= f.number_field :monto, class: "form-control", min: 0, step: 100, required: true,
          id: "concepto-monto", oninput: "calcularResultado()" %>
    </div>
  </div>

  <div class="col-md-4">
    <%= f.label :descripcion, "Descripci&oacute;n (opcional)".html_safe, class: "form-label" %>
    <%= f.text_field :descripcion, class: "form-control", placeholder: "Breve descripci&oacute;n" %>
  </div>

  <% if @concepto.persisted? %>
    <div class="col-md-4">
      <div class="form-check form-switch mt-4">
        <%= f.check_box :activo, class: "form-check-input", role: "switch", id: "concepto-activo" %>
        <label class="form-check-label" for="concepto-activo">Concepto activo</label>
      </div>
    </div>
  <% end %>

  <%# Info dinámica según tipo %>
  <div class="col-12" id="info-por-logia" style="<%= 'display:none;' unless @concepto.por_logia? %>">
    <div class="alert alert-info mb-0">
      <i class="bi bi-info-circle me-2"></i>
      <strong>Miembros activos:</strong> <%= activos_count %>
      &mdash;
      <strong>Monto por miembro:</strong>
      <span id="resultado-division">
        <% if @concepto.por_logia? && @concepto.monto.to_i > 0 %>
          <%= number_to_currency(@concepto.monto_por_miembro, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
        <% else %>
          $0
        <% end %>
      </span>
    </div>
  </div>

  <div class="col-12" id="info-complemento" style="<%= 'display:none;' unless @concepto.complemento? %>">
    <div class="alert alert-warning mb-0">
      <i class="bi bi-calculator me-2"></i>
      <strong>Suma de otros conceptos por miembro:</strong>
      <span id="suma-otros"><%= number_to_currency(suma_otros, unit: "$", delimiter: ".", separator: ",", precision: 0) %></span>
      <br>
      <strong>Aporte al Tesoro (diferencia):</strong>
      <span id="resultado-complemento" class="fs-5">
        <% if @concepto.complemento? && @concepto.monto.to_i > 0 %>
          <%= number_to_currency(@concepto.residuo, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
        <% else %>
          $0
        <% end %>
      </span>
      <span class="text-muted ms-2">por miembro</span>
    </div>
  </div>

  <div class="col-12">
    <%= f.submit @concepto.persisted? ? "Actualizar Concepto" : "Crear Concepto", class: "btn btn-primary" %>
    <%= link_to "Cancelar", logia_conceptos_cobro_path(@logia), class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<script>
  var miembrosActivos = <%= activos_count %>;
  var sumaOtros = <%= suma_otros.to_i %>;

  function actualizarTipo() {
    var tipo = document.getElementById("concepto-tipo").value;
    var label = document.getElementById("monto-label");
    var infoLogia = document.getElementById("info-por-logia");
    var infoComplemento = document.getElementById("info-complemento");

    infoLogia.style.display = "none";
    infoComplemento.style.display = "none";

    if (tipo === "por_logia") {
      label.textContent = "Monto Total de la Logia";
      infoLogia.style.display = "";
    } else if (tipo === "complemento") {
      label.textContent = "Cuota Per Cápita Total";
      infoComplemento.style.display = "";
    } else {
      label.textContent = "Monto por Miembro";
    }
    calcularResultado();
  }

  function calcularResultado() {
    var tipo = document.getElementById("concepto-tipo").value;
    var monto = parseFloat(document.getElementById("concepto-monto").value) || 0;

    if (tipo === "por_logia" && miembrosActivos > 0) {
      var porMiembro = Math.round(monto / miembrosActivos);
      document.getElementById("resultado-division").textContent = "$ " + porMiembro.toLocaleString("es-CO");
    }

    if (tipo === "complemento") {
      var residuo = Math.max(monto - sumaOtros, 0);
      document.getElementById("resultado-complemento").textContent = "$ " + residuo.toLocaleString("es-CO");
    }
  }
</script>
