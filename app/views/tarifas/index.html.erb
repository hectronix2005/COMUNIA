<% content_for(:title, "Historial de Tarifas - #{@logia.nombre}") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1">
        <li class="breadcrumb-item"><%= link_to "Periodos", periodo_cobros_path %></li>
        <li class="breadcrumb-item active">Tarifas - <%= @logia.nombre %></li>
      </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0">
      <i class="bi bi-tag me-2"></i>Historial de Tarifas
      <small class="text-muted fw-normal ms-2"><%= @logia.nombre %></small>
    </h1>
  </div>
  <div class="d-flex gap-2">
    <% if policy(@logia).gestionar_conceptos? %>
      <%= link_to new_logia_tarifa_path(@logia), class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i>Nueva Tarifa
      <% end %>
    <% end %>
    <%= link_to periodo_cobros_path, class: "btn btn-outline-dark" do %>
      <i class="bi bi-arrow-left me-1"></i>Periodos
    <% end %>
  </div>
</div>

<%# ── Tarifa Vigente ── %>
<% if @tarifa_actual %>
  <div class="card border-success mb-4">
    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
      <h5 class="mb-0"><i class="bi bi-check-circle me-2"></i>Tarifa Vigente</h5>
      <span class="badge bg-white text-success"><%= @tarifa_actual.rango_texto %></span>
    </div>
    <div class="card-body">
      <div class="row align-items-center">
        <div class="col-md-4">
          <div class="text-center">
            <small class="text-muted d-block">Cuota Mensual por Miembro</small>
            <span class="fs-2 fw-bold text-success"><%= number_to_currency(@tarifa_actual.monto, unit: "$", delimiter: ".", separator: ",", precision: 0) %></span>
          </div>
        </div>
        <div class="col-md-8">
          <% if @tarifa_actual.desglose.present? %>
            <table class="table table-sm mb-0">
              <tbody>
                <% @tarifa_actual.desglose.each do |item| %>
                  <tr>
                    <td><%= item["nombre"] %></td>
                    <td class="text-muted small"><%= item["tipo"]&.humanize %></td>
                    <td class="text-end fw-semibold"><%= number_to_currency(item["monto_por_miembro"] || item["monto"], unit: "$", delimiter: ".", separator: ",", precision: 0) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <p class="text-muted mb-0">Sin desglose registrado.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <div class="alert alert-warning mb-4">
    <i class="bi bi-exclamation-triangle me-2"></i>
    No hay tarifa registrada. Se utiliza el monto calculado de los conceptos:
    <strong><%= number_to_currency(@monto_mensual_actual, unit: "$", delimiter: ".", separator: ",", precision: 0) %></strong>
    <% if policy(@logia).gestionar_conceptos? %>
      &mdash; <%= link_to "Registrar tarifa actual", new_logia_tarifa_path(@logia), class: "alert-link" %>
    <% end %>
  </div>
<% end %>

<%# ── Desglose actual de conceptos ── %>
<% if @conceptos.any? %>
  <div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h6 class="mb-0"><i class="bi bi-list-columns-reverse me-2"></i>Desglose Actual de Conceptos</h6>
      <%= link_to logia_conceptos_cobro_path(@logia), class: "btn btn-sm btn-outline-primary" do %>
        <i class="bi bi-pencil me-1"></i>Editar Conceptos
      <% end %>
    </div>
    <div class="card-body p-0">
      <table class="table table-sm mb-0">
        <tbody>
          <% @conceptos.each do |c| %>
            <tr>
              <td class="ps-3"><%= c.nombre %></td>
              <td class="text-muted small"><%= c.tipo.humanize %></td>
              <td class="text-end"><%= number_to_currency(c.monto, unit: "$", delimiter: ".", separator: ",", precision: 0) %></td>
              <td class="text-end pe-3 fw-semibold"><%= number_to_currency(c.monto_por_miembro, unit: "$", delimiter: ".", separator: ",", precision: 0) %>/miembro</td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="table-dark">
          <tr>
            <td class="ps-3" colspan="3"><strong>TOTAL</strong></td>
            <td class="text-end pe-3"><strong><%= number_to_currency(@monto_mensual_actual, unit: "$", delimiter: ".", separator: ",", precision: 0) %>/miembro</strong></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
<% end %>

<%# ── Historial de Tarifas ── %>
<div class="card">
  <div class="card-header">
    <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Historial de Tarifas</h6>
  </div>
  <% if @tarifas.any? %>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th class="ps-3">Vigencia</th>
            <th class="text-end">Cuota Mensual</th>
            <th>Desglose</th>
            <th class="text-muted small">Registrada por</th>
            <th class="text-center pe-3">Estado</th>
            <% if policy(@logia).gestionar_conceptos? %>
              <th class="text-center">Acciones</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @tarifas.each do |tarifa| %>
            <tr class="<%= 'table-success' if tarifa.vigente? %>">
              <td class="ps-3">
                <strong><%= I18n.l(tarifa.vigente_desde, format: :short) rescue tarifa.vigente_desde %></strong>
                <span class="text-muted"> &mdash; <%= I18n.l(tarifa.vigente_hasta, format: :short) rescue tarifa.vigente_hasta %></span>
              </td>
              <td class="text-end">
                <strong class="fs-5"><%= number_to_currency(tarifa.monto, unit: "$", delimiter: ".", separator: ",", precision: 0) %></strong>
              </td>
              <td>
                <% if tarifa.desglose.present? %>
                  <small class="text-muted">
                    <% tarifa.desglose.each_with_index do |item, i| %>
                      <%= item["nombre"] %>: <strong><%= number_to_currency(item["monto_por_miembro"] || item["monto"], unit: "$", delimiter: ".", separator: ",", precision: 0) %></strong><%= i < tarifa.desglose.size - 1 ? " | " : "" %>
                    <% end %>
                  </small>
                <% else %>
                  <span class="text-muted small">Sin desglose</span>
                <% end %>
              </td>
              <td class="text-muted small"><%= tarifa.creado_por&.nombre_completo rescue tarifa.creado_por&.email %></td>
              <td class="text-center pe-3">
                <% if tarifa.vigente? %>
                  <span class="badge bg-success">Vigente</span>
                <% else %>
                  <span class="badge bg-secondary">Historial</span>
                <% end %>
              </td>
              <% if policy(@logia).gestionar_conceptos? %>
                <td class="text-center">
                  <div class="d-flex gap-1 justify-content-center">
                    <%= link_to edit_logia_tarifa_path(@logia, tarifa), class: "btn btn-sm btn-outline-primary" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= button_to logia_tarifa_path(@logia, tarifa), method: :delete,
                          class: "btn btn-sm btn-outline-danger",
                          form: { data: { turbo_confirm: "¿Eliminar esta tarifa?" } } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-body text-center py-4 text-muted">
      <i class="bi bi-inbox display-4 d-block mb-2"></i>
      No hay tarifas registradas.
      <% if policy(@logia).gestionar_conceptos? %>
        <br><%= link_to "Registrar la primera tarifa", new_logia_tarifa_path(@logia), class: "btn btn-primary mt-3" %>
      <% end %>
    </div>
  <% end %>
</div>
