<%= form_with(model: @rol, url: @rol.persisted? ? role_path(@rol) : roles_path, class: "needs-validation") do |f| %>
  <% if @rol.errors.any? %>
    <div class="alert alert-danger">
      <h4 class="alert-heading">Se encontraron <%= pluralize(@rol.errors.count, "error") %>:</h4>
      <ul class="mb-0">
        <% @rol.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :nombre, class: "form-label" %>
    <%= f.text_field :nombre, class: "form-control #{'is-invalid' if @rol.errors[:nombre].any?}", placeholder: "Ej: Tesorero" %>
    <% if @rol.errors[:nombre].any? %>
      <div class="invalid-feedback"><%= @rol.errors[:nombre].join(", ") %></div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :codigo, class: "form-label" %>
    <%= f.text_field :codigo, class: "form-control #{'is-invalid' if @rol.errors[:codigo].any?}", placeholder: "Ej: tesorero" %>
    <% if @rol.errors[:codigo].any? %>
      <div class="invalid-feedback"><%= @rol.errors[:codigo].join(", ") %></div>
    <% end %>
    <div class="form-text">Identificador unico en minusculas, sin espacios.</div>
  </div>

  <div class="mb-3">
    <%= f.label :descripcion, class: "form-label" %>
    <%= f.text_field :descripcion, class: "form-control", placeholder: "Descripcion opcional del rol" %>
  </div>

  <% if current_user.rol_ref&.es_super_admin? %>
    <%
      tenants = Logia.tenants_raiz.ordenadas.includes(:logias)
      actual  = @rol.logia
      tenant_seleccionado_id = if actual
        actual.tenant_id.nil? ? actual.id : actual.tenant_id
      end
      grupo_seleccionado_id = (actual && actual.tenant_id.present?) ? actual.id : nil
    %>
    <div class="mb-3">
      <%= label_tag :tenant_id_ui, "Tenant", class: "form-label" %>
      <%= select_tag :tenant_id_ui,
            options_from_collection_for_select(tenants, :id, :nombre_display, tenant_seleccionado_id),
            include_blank: "— COMUNIA (todos los tenants) —",
            class: "form-select",
            id: "rol-tenant-select" %>
      <div class="form-text">Dejar vacío para un rol compartido entre todos los tenants.</div>
    </div>

    <div class="mb-3">
      <%= f.label :logia_id, "Grupo", class: "form-label" %>
      <select name="rol[logia_id]" id="rol-grupo-select" class="form-select">
        <option value="">— Todo el tenant —</option>
        <% tenants.each do |t| %>
          <% t.logias.order(:codigo).each do |g| %>
            <option value="<%= g.id %>"
                    data-tenant-id="<%= t.id %>"
                    <%= "selected" if g.id == grupo_seleccionado_id %>>
              <%= g.codigo %> <%= g.nombre_display %>
            </option>
          <% end %>
        <% end %>
      </select>
      <div class="form-text">Opcional. Selecciona un grupo específico dentro del tenant.</div>
    </div>

    <script>
      (function() {
        const tenantSel = document.getElementById('rol-tenant-select');
        const grupoSel  = document.getElementById('rol-grupo-select');
        if (!tenantSel || !grupoSel) return;

        function syncGrupos() {
          const tenantId = tenantSel.value;
          let primerVisible = null;
          Array.from(grupoSel.options).forEach(opt => {
            if (!opt.value) { opt.hidden = false; return; }
            const visible = String(opt.dataset.tenantId) === String(tenantId);
            opt.hidden = !visible;
            if (visible && !primerVisible) primerVisible = opt;
          });
          if (!tenantId) {
            grupoSel.value = '';
            grupoSel.disabled = true;
          } else {
            grupoSel.disabled = false;
            const sel = grupoSel.options[grupoSel.selectedIndex];
            if (!sel || sel.hidden) grupoSel.value = '';
          }
        }

        tenantSel.addEventListener('change', function() {
          const tenantId = tenantSel.value;
          grupoSel.value = '';
          syncGrupos();
          // If no grupo chosen and tenant chosen, submit tenant as logia_id via hidden fallback
          updateHiddenTenant();
        });

        grupoSel.addEventListener('change', updateHiddenTenant);

        // Hidden input that carries the tenant id when no grupo is selected
        let hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'rol[logia_id]';
        grupoSel.parentNode.appendChild(hidden);

        function updateHiddenTenant() {
          if (grupoSel.value) {
            hidden.disabled = true;
            grupoSel.disabled = false;
            grupoSel.name = 'rol[logia_id]';
          } else {
            grupoSel.name = '';
            hidden.disabled = false;
            hidden.value = tenantSel.value || '';
          }
        }

        syncGrupos();
        updateHiddenTenant();
      })();
    </script>
  <% end %>

  <div class="mt-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancelar", roles_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
