<%= form_with(model: logia, url: url, method: local_assigns.fetch(:http_method, :post), class: "needs-validation") do |f| %>
  <% if logia.errors.any? %>
    <div class="alert alert-danger">
      <h4 class="alert-heading">Se encontraron <%= pluralize(logia.errors.count, "error") %>:</h4>
      <ul class="mb-0">
        <% logia.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Identificación básica ──────────────────────────────── %>
  <div class="row g-3 mb-4">
    <div class="col-md-5">
      <%= f.label :nombre, class: "form-label fw-semibold" %>
      <%= f.text_field :nombre, class: "form-control #{'is-invalid' if logia.errors[:nombre].any?}" %>
      <% if logia.errors[:nombre].any? %>
        <div class="invalid-feedback"><%= logia.errors[:nombre].join(", ") %></div>
      <% end %>
    </div>
    <div class="col-md-2">
      <%= f.label :codigo, class: "form-label fw-semibold" %>
      <%= f.text_field :codigo, class: "form-control #{'is-invalid' if logia.errors[:codigo].any?}", placeholder: "TEN001" %>
      <% if logia.errors[:codigo].any? %>
        <div class="invalid-feedback"><%= logia.errors[:codigo].join(", ") %></div>
      <% end %>
    </div>
    <div class="col-md-3">
      <%= f.label :slug, "Subdominio / Slug", class: "form-label fw-semibold" %>
      <%= f.text_field :slug, class: "form-control #{'is-invalid' if logia.errors[:slug].any?}", placeholder: "mi-tenant" %>
      <%
        _base = request.host.split(".").drop(1).join(".")
        _port = (request.port != 80 && request.port != 443) ? ":#{request.port}" : ""
        _base_with_port = _base.present? ? "#{_base}#{_port}" : "#{request.host}#{_port}"
        _preview_slug = logia.slug.presence || "mi-tenant"
      %>
      <div class="form-text">URL: <strong><%= _preview_slug %>.<%= _base_with_port %></strong></div>
      <% if logia.errors[:slug].any? %>
        <div class="invalid-feedback"><%= logia.errors[:slug].join(", ") %></div>
      <% end %>
    </div>
    <div class="col-md-2">
      <%= f.label :tenant_id, "Pertenece a tenant", class: "form-label fw-semibold" %>
      <%
        otros_tenants = Logia.tenants_raiz.where.not(id: logia.id).ordenadas
      %>
      <%= f.select :tenant_id,
            options_from_collection_for_select(otros_tenants, :id, :nombre_display, logia.tenant_id),
            { include_blank: "— Ninguno (es tenant raíz) —" },
            class: "form-select" %>
      <div class="form-text">Asignar convierte esta entrada en una logia hija.</div>
    </div>
  </div>

  <% if logia.tenant_id.nil? %>
    <%# ── Branding / White-label (solo para tenants raíz) ──── %>
    <div class="card border-secondary mb-4">
      <div class="card-header bg-light">
        <h6 class="mb-0"><i class="bi bi-palette me-2"></i>Personalización (White-label)</h6>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-5">
            <%= f.label :nombre_app, "Nombre de la app", class: "form-label" %>
            <%= f.text_field :nombre_app, class: "form-control", placeholder: "Ej: Mi Organización" %>
            <div class="form-text">Si está vacío se usa el nombre del tenant.</div>
          </div>
          <div class="col-md-2">
            <%= f.label :icono, "Icono (emoji)", class: "form-label" %>
            <%
              emoji_groups = {
                "Organizaciones" => %w[🏛️ 🏢 🏦 ⚖️ 🔱 🎖️ 🏅 👑 🛡️ ⚜️ 🔑 🗝️ 📜 🕍 ⛪ 🕌],
                "Personas"       => %w[🤝 👥 👤 🧑‍🤝‍🧑 🫂 🙏 💼 🧑‍💼 👨‍💼 👩‍💼],
                "Símbolos"       => %w[⭐ 🌟 💫 ✨ 🔥 💎 🌐 🌍 🌎 🌏 🏆 🎗️ 🎯 🧭 🔭 🔬],
                "Naturaleza"     => %w[🌿 🍃 🌱 🌲 🌳 🌴 🌺 🌸 🌹 🦅 🦁 🐯 🦋 🐝 🌊 🏔️],
                "Otros"          => %w[💡 🔔 📣 📢 📌 📍 🗺️ 🧱 🏗️ ⚙️ 🔧 🔩 🛠️ 🎵 🎶 🎨]
              }
            %>
            <div class="dropdown">
              <button type="button"
                      class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-between"
                      data-bs-toggle="dropdown"
                      data-bs-auto-close="outside"
                      aria-expanded="false"
                      id="emoji-picker-btn">
                <span id="emoji-preview" style="font-size:1.4rem; line-height:1;">
                  <%= logia.icono.presence || "🏢" %>
                </span>
                <i class="bi bi-chevron-down ms-2 text-muted small"></i>
              </button>
              <%= f.hidden_field :icono, id: "logia_icono_value", value: logia.icono.presence || "🏢" %>
              <div class="dropdown-menu p-2" style="min-width:260px; max-height:300px; overflow-y:auto;">
                <% emoji_groups.each do |group_name, emojis| %>
                  <p class="text-muted small fw-semibold px-1 mb-1 mt-2"><%= group_name %></p>
                  <div class="d-flex flex-wrap gap-1 mb-1">
                    <% emojis.each do |emoji| %>
                      <button type="button"
                              class="btn btn-sm btn-outline-light emoji-opt"
                              style="font-size:1.3rem; width:2.2rem; height:2.2rem; padding:0; line-height:1;"
                              data-emoji="<%= emoji %>"
                              title="<%= emoji %>">
                        <%= emoji %>
                      </button>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
          <div class="col-md-2">
            <%= f.label :color_primario, "Color primario", class: "form-label" %>
            <div class="input-group">
              <input type="color" value="<%= logia.color_display %>"
                     class="form-control form-control-color"
                     oninput="document.getElementById('tenant_color_text').value=this.value">
              <%= f.text_field :color_primario, class: "form-control", placeholder: "#1B2A4A",
                               id: "tenant_color_text",
                               value: (logia.color_primario.presence || "#1B2A4A") %>
            </div>
          </div>
          <div class="col-md-3">
            <%= f.label :logo, "Logo (imagen)", class: "form-label" %>
            <%= f.file_field :logo, class: "form-control", accept: "image/*,image/svg+xml" %>
            <% if logia.logo.attached? %>
              <div class="mt-1">
                <%= image_tag logia.logo, height: 30, class: "rounded" %>
                <small class="text-muted ms-1">Logo actual</small>
              </div>
            <% end %>
          </div>
          <div class="col-12">
            <%= f.label :lema, "Lema / tagline", class: "form-label" %>
            <%= f.text_field :lema, class: "form-control", placeholder: "Ej: Unidos construimos más" %>
          </div>
        </div>

        <hr class="my-3">
        <h6 class="text-muted small mb-3">
          Terminología personalizada
          <span class="fw-normal">(dejar vacío usa el término por defecto del sistema)</span>
        </h6>
        <div class="row g-3">
          <div class="col-md-4">
            <%= f.label :termino_miembro, "Cómo llamar a cada persona", class: "form-label" %>
            <%= f.text_field :termino_miembro, class: "form-control", placeholder: "Ej: Socio, Hermano, Miembro" %>
            <div class="form-text">Aparece en menús y listados.</div>
          </div>
          <div class="col-md-4">
            <%= f.label :termino_logia, "Término para sub-unidades", class: "form-label" %>
            <%= f.text_field :termino_logia, class: "form-control", placeholder: "Ej: Logia, Grupo, Capítulo, Sede" %>
            <div class="form-text">Etiqueta de cada capítulo dentro del tenant.</div>
          </div>
          <div class="col-md-4">
            <%= f.label :termino_cobro, "Cómo llamar a los cobros", class: "form-label" %>
            <%= f.text_field :termino_cobro, class: "form-control", placeholder: "Ej: Cuota, Aporte, Pago" %>
            <div class="form-text">Aparece en menús financieros.</div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mt-2">
    <%= f.submit (submit_label || "Guardar"), class: "btn btn-primary" %>
    <%= link_to "Cancelar", tenants_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>

<script>
  document.querySelectorAll(".emoji-opt").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var emoji = this.dataset.emoji;
      document.getElementById("emoji-preview").textContent = emoji;
      document.getElementById("logia_icono_value").value = emoji;
      // close the dropdown
      var dropdownEl = document.getElementById("emoji-picker-btn");
      bootstrap.Dropdown.getInstance(dropdownEl)?.hide();
    });
  });
</script>
