<% content_for(:title, "Nuevo Tenant — COMUNIA") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-plus-circle me-2"></i>Nuevo Tenant</h1>
  <%= link_to tenants_path, class: "btn btn-outline-secondary btn-sm" do %>
    <i class="bi bi-arrow-left me-1"></i>Volver
  <% end %>
</div>

<div class="card">
  <div class="card-body">
    <%= render "form", logia: @tenant, url: tenants_path, submit_label: "Crear Tenant" %>
  </div>
</div>
