<% content_for(:title, "Configurar #{@tenant.nombre_display} — COMUNIA") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-0">
      <%= @tenant.icono_display %> <%= @tenant.nombre_display %>
    </h1>
    <small class="text-muted">Configuración del tenant</small>
  </div>
  <%= link_to tenant_path(@tenant), class: "btn btn-outline-secondary btn-sm" do %>
    <i class="bi bi-arrow-left me-1"></i>Volver
  <% end %>
</div>

<%# ── Branding ─────────────────────────────────────────────── %>
<div class="card mb-4">
  <div class="card-header bg-light">
    <h6 class="mb-0"><i class="bi bi-palette me-2"></i>Branding y configuración</h6>
  </div>
  <div class="card-body">
    <%= render "form", logia: @tenant, url: tenant_path(@tenant), http_method: :patch, submit_label: "Guardar cambios" %>
  </div>
</div>

<%# ── Administradores del Tenant ──────────────────────────── %>
<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center"
       style="background: <%= @tenant.color_display %>; color: #fff;">
    <h6 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Administradores del Tenant</h6>
    <button class="btn btn-sm btn-light text-dark fw-semibold"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#form-nuevo-admin-tenant"
            aria-expanded="false">
      <i class="bi bi-plus-circle me-1"></i>Nuevo administrador
    </button>
  </div>

  <%# ── Formulario crear admin ──────────────────────────────── %>
  <div class="collapse" id="form-nuevo-admin-tenant">
    <div class="card-body border-bottom bg-light">
      <%= form_with url: crear_admin_tenant_tenant_path(@tenant), method: :post, class: "row g-2 align-items-end" do |f| %>
        <div class="col-md-3">
          <label class="form-label small fw-semibold mb-1">Nombre</label>
          <input type="text" name="admin_tenant[nombre]" class="form-control form-control-sm" required placeholder="Ej: Juan">
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold mb-1">Apellido</label>
          <input type="text" name="admin_tenant[apellido]" class="form-control form-control-sm" required placeholder="Ej: Pérez">
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold mb-1">Correo electrónico</label>
          <input type="email" name="admin_tenant[email]" class="form-control form-control-sm" required placeholder="correo@ejemplo.com">
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold mb-1">Contraseña</label>
          <input type="password" name="admin_tenant[password]" class="form-control form-control-sm" required minlength="6">
        </div>
        <div class="col-md-1 d-grid">
          <button type="submit" class="btn btn-primary btn-sm" title="Crear administrador">
            <i class="bi bi-check-lg"></i>
          </button>
        </div>
      <% end %>
      <p class="text-muted small mb-0 mt-2 px-1">
        <i class="bi bi-info-circle me-1"></i>
        Este usuario podrá gestionar <strong>todas las <%= @tenant.t_logia.downcase.pluralize %></strong>
        y <strong>todos los <%= @tenant.t_miembro.downcase.pluralize %></strong>
        de <strong><%= @tenant.nombre_display %></strong>.
      </p>
    </div>
  </div>

  <%# ── Lista de admins actuales ─────────────────────────────── %>
  <div class="card-body p-0">
    <% if @admins_tenant.any? %>
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Usuario</th>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Alcance</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @admins_tenant.each do |admin| %>
            <tr>
              <td><code><%= admin.username %></code></td>
              <td><%= admin.nombre_completo %></td>
              <td class="text-muted small"><%= admin.email %></td>
              <td>
                <span class="badge bg-primary">
                  <i class="bi bi-diagram-3 me-1"></i>Todo <%= @tenant.nombre_display %>
                </span>
              </td>
              <td class="text-end">
                <%= button_to quitar_admin_tenant_tenant_path(@tenant),
                      method: :delete,
                      params: { user_id: admin.id },
                      class: "btn btn-sm btn-outline-danger",
                      form: { data: { turbo_confirm: "¿Quitar rol de administrador a #{admin.nombre_completo}?" } } do %>
                  <i class="bi bi-person-dash"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">
        <i class="bi bi-shield-exclamation fs-2 d-block mb-2"></i>
        Este tenant no tiene administrador asignado aún.
      </div>
    <% end %>
  </div>
</div>
