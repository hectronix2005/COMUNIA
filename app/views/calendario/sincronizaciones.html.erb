<% content_for(:title, "Sincronizaciones de Calendario") %>

<div class="container" style="max-width:760px;margin-top:1.5rem;">

  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h5 class="mb-0 fw-bold"><i class="bi bi-arrow-repeat me-2" style="color:#1B2A4A;"></i>Sincronizaciones de Calendario</h5>
      <div class="text-muted small mt-1">Gestiona qué logias pueden ver tu calendario</div>
    </div>
    <%= link_to calendario_index_path, class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-calendar3 me-1"></i>Volver al calendario
    <% end %>
  </div>

  <div class="row g-4">

    <%# ── Solicitar nueva sync ── %>
    <% if @logias_sin_sync.any? %>
      <div class="col-12">
        <div class="card border-0 shadow-sm">
          <div class="card-header fw-semibold" style="background:#f8f9fa;font-size:.85rem;">
            <i class="bi bi-send me-2"></i>Solicitar sincronización con otra logia
          </div>
          <div class="card-body p-3">
            <%= form_with url: calendario_solicitar_sync_path, method: :post, class: "row g-2 align-items-end" do |f| %>
              <div class="col-sm-5">
                <label class="form-label small text-muted mb-1">Logia destino</label>
                <%= f.select :logia_destino_id,
                      @logias_sin_sync.map { |l| [l.nombre_display, l.id] },
                      { include_blank: "Seleccionar logia…" },
                      class: "form-select form-select-sm" %>
              </div>
              <div class="col-sm-5">
                <label class="form-label small text-muted mb-1">Mensaje (opcional)</label>
                <%= f.text_field :mensaje,
                      class: "form-control form-control-sm",
                      placeholder: "Motivo de la solicitud…" %>
              </div>
              <div class="col-sm-2">
                <%= f.submit "Enviar", class: "btn btn-sm w-100 text-white", style: "background:#1B2A4A;" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# ── Lista de solicitudes ── %>
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header fw-semibold d-flex justify-content-between align-items-center" style="background:#f8f9fa;font-size:.85rem;">
          <span><i class="bi bi-list-ul me-2"></i>Historial de solicitudes</span>
          <% pendientes = @solicitudes.select(&:pendiente?) %>
          <% if pendientes.any? %>
            <span class="badge bg-danger"><%= pendientes.size %> pendiente<%= pendientes.size > 1 ? "s" : "" %></span>
          <% end %>
        </div>

        <% if @solicitudes.empty? %>
          <div class="card-body text-center text-muted py-5">
            <i class="bi bi-arrow-repeat fs-2 d-block mb-2"></i>
            No hay solicitudes de sincronización aún.
          </div>
        <% else %>
          <ul class="list-group list-group-flush">
            <% @solicitudes.each do |s| %>
              <li class="list-group-item py-3 px-4">
                <div class="d-flex align-items-center justify-content-between gap-3">
                  <div class="d-flex align-items-center gap-3">
                    <%# Direction indicator %>
                    <% if s.logia_solicitante_id == current_logia.id %>
                      <span class="badge bg-secondary" style="font-size:.65rem;">Enviada</span>
                    <% else %>
                      <span class="badge" style="background:#1B2A4A;font-size:.65rem;">Recibida</span>
                    <% end %>

                    <div>
                      <div class="fw-semibold small">
                        <% if s.logia_solicitante_id == current_logia.id %>
                          → <%= s.logia_destino.nombre_display %>
                        <% else %>
                          ← <%= s.logia_solicitante.nombre_display %>
                        <% end %>
                      </div>
                      <div class="text-muted" style="font-size:.72rem;">
                        Solicitado por <%= s.solicitado_por.nombre_completo %> · <%= s.created_at.strftime("%d/%m/%Y") %>
                        <% if s.mensaje.present? %>
                          · "<%= s.mensaje.truncate(60) %>"
                        <% end %>
                      </div>
                    </div>
                  </div>

                  <div class="d-flex align-items-center gap-2">
                    <%# Status badge %>
                    <% case s.estado
                       when "pendiente" %>
                      <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Pendiente</span>
                    <% when "aceptada" %>
                      <span class="badge bg-success"><i class="bi bi-check2 me-1"></i>Activa</span>
                    <% when "rechazada" %>
                      <span class="badge bg-danger"><i class="bi bi-x me-1"></i>Rechazada</span>
                    <% end %>

                    <%# Accept/reject buttons if this logia is the destination and still pending %>
                    <% if s.logia_destino_id == current_logia.id && s.pendiente? %>
                      <%= form_with url: calendario_responder_sync_path(s), method: :patch, class: "d-inline" do |f| %>
                        <%= hidden_field_tag :accion, "aceptar" %>
                        <%= f.submit "Aceptar", class: "btn btn-sm btn-success py-0 px-2", style: "font-size:.75rem;" %>
                      <% end %>
                      <%= form_with url: calendario_responder_sync_path(s), method: :patch, class: "d-inline" do |f| %>
                        <%= hidden_field_tag :accion, "rechazar" %>
                        <%= f.submit "Rechazar", class: "btn btn-sm btn-outline-danger py-0 px-2", style: "font-size:.75rem;" %>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>
    </div>

  </div>
</div>
