<% content_for(:title, "Calendario — #{current_logia.nombre_display}") %>
<% content_for :head do %>
  <style>
    /* ── Layout ────────────────────────────────────────────── */
    .cal-layout        { display:flex; height:calc(100vh - 130px); gap:0; overflow:hidden; }
    .cal-sidebar       { width:240px; min-width:200px; border-right:1px solid #dee2e6; display:flex; flex-direction:column; background:#fff; overflow-y:auto; }
    .cal-main          { flex:1; display:flex; flex-direction:column; min-width:0; background:#fff; }

    /* ── Sidebar mini-calendar ─────────────────────────────── */
    .mini-cal          { padding:12px 16px; }
    .mini-cal-head     { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; font-size:.8rem; font-weight:700; color:#3c4043; }
    .mini-cal-grid     { display:grid; grid-template-columns:repeat(7,1fr); text-align:center; }
    .mini-cal-dow      { font-size:.65rem; color:#70757a; padding:2px 0; font-weight:600; }
    .mini-cal-day      { font-size:.75rem; width:24px; height:24px; display:flex; align-items:center; justify-content:center;
                         border-radius:50%; cursor:pointer; margin:1px auto; color:#3c4043; text-decoration:none; }
    .mini-cal-day:hover { background:#f1f3f4; }
    .mini-cal-day.today { background:#1B2A4A; color:#fff !important; }
    .mini-cal-day.sel   { background:#e8f0fe; color:#1B2A4A; font-weight:700; }
    .mini-cal-day.otro-mes { color:#bdc1c6; }

    /* ── Sidebar sections ──────────────────────────────────── */
    .cal-sb-section    { padding:12px 16px; border-top:1px solid #f0f1f3; }
    .cal-sb-label      { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#70757a; margin-bottom:8px; }
    .cal-legend-item   { display:flex; align-items:center; gap:8px; font-size:.8rem; color:#3c4043; margin-bottom:5px; }
    .cal-legend-dot    { width:12px; height:12px; border-radius:50%; flex-shrink:0; }
    .cal-filter-btn    { display:block; width:100%; text-align:left; padding:5px 10px; border-radius:20px; font-size:.8rem;
                         border:none; background:transparent; cursor:pointer; color:#3c4043; }
    .cal-filter-btn:hover    { background:#f1f3f4; }
    .cal-filter-btn.active   { background:#e8f0fe; color:#1B2A4A; font-weight:600; }

    /* ── Main toolbar ──────────────────────────────────────── */
    .cal-toolbar       { display:flex; align-items:center; gap:12px; padding:10px 20px; border-bottom:1px solid #dee2e6; flex-shrink:0; }
    .cal-toolbar-title { font-size:1.25rem; font-weight:400; color:#3c4043; min-width:180px; }
    .cal-view-btns     { display:flex; border:1px solid #dadce0; border-radius:4px; overflow:hidden; }
    .cal-view-btn      { padding:5px 14px; font-size:.8rem; border:none; background:#fff; cursor:pointer; color:#3c4043; }
    .cal-view-btn:hover { background:#f1f3f4; }
    .cal-view-btn.active { background:#e8f0fe; color:#1B2A4A; font-weight:600; }
    .cal-view-btn + .cal-view-btn { border-left:1px solid #dadce0; }

    /* ── Month grid ─────────────────────────────────────────── */
    .cal-month         { flex:1; overflow-y:auto; }
    .cal-month-head    { display:grid; grid-template-columns:repeat(7,1fr); border-bottom:1px solid #dadce0; flex-shrink:0; }
    .cal-month-dow     { text-align:center; padding:8px 0; font-size:.75rem; font-weight:600; color:#70757a; text-transform:uppercase; letter-spacing:.04em; }
    .cal-month-grid    { display:grid; grid-template-columns:repeat(7,1fr); flex:1; }
    .cal-day           { min-height:100px; border-right:1px solid #dadce0; border-bottom:1px solid #dadce0; padding:4px; overflow:hidden; cursor:pointer; }
    .cal-day:hover     { background:#f8f9fa; }
    .cal-day.otro-mes  { background:#f8f9fa; }
    .cal-day.hoy       { /* highlight today */ }
    .cal-day-num       { font-size:.82rem; width:26px; height:26px; display:flex; align-items:center; justify-content:center;
                         border-radius:50%; font-weight:500; color:#3c4043; margin-bottom:2px; }
    .cal-day.hoy .cal-day-num { background:#1B2A4A; color:#fff; }
    .cal-day-num.otro-mes { color:#bdc1c6; }
    .cal-chip          { display:block; font-size:.72rem; padding:1px 6px; border-radius:3px; margin-bottom:2px;
                         white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:#fff; cursor:pointer;
                         text-decoration:none; line-height:1.7; }
    .cal-chip:hover    { opacity:.85; color:#fff; }
    .cal-chip.todo-dia { border-radius:3px; }
    .cal-chip.timed    { background:transparent !important; color:#3c4043 !important; font-weight:500; }
    .cal-chip.timed::before { content:"●"; margin-right:4px; }
    .cal-mas           { font-size:.7rem; color:#70757a; padding:1px 6px; cursor:pointer; }
    .cal-mas:hover     { background:#f1f3f4; border-radius:3px; }

    /* ── Day popover ────────────────────────────────────────── */
    #cal-popover       { position:fixed; z-index:1060; background:#fff; border-radius:8px;
                         box-shadow:0 4px 24px rgba(0,0,0,.22); min-width:220px; max-width:290px;
                         display:none; overflow:hidden; }
    .cal-pop-header    { padding:12px 16px 8px; font-size:.78rem; font-weight:700; color:#3c4043;
                         border-bottom:1px solid #f0f1f3; }
    .cal-pop-evento    { display:flex; align-items:center; gap:8px; padding:6px 16px;
                         text-decoration:none; color:#3c4043; font-size:.8rem; transition:background .1s; }
    .cal-pop-evento:hover { background:#f8f9fa; color:#1B2A4A; }
    .cal-pop-dot       { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
    .cal-pop-hora      { color:#70757a; font-size:.7rem; min-width:50px; flex-shrink:0; }
    .cal-pop-titulo    { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .cal-pop-recur     { color:#70757a; font-size:.65rem; margin-left:2px; }
    .cal-pop-footer    { padding:8px 16px 10px; border-top:1px solid #f0f1f3; }
    .cal-pop-new       { display:flex; align-items:center; gap:6px; text-decoration:none;
                         color:#1B2A4A; font-size:.8rem; font-weight:600; }
    .cal-pop-new:hover { color:#0d1f38; }
    .cal-pop-empty     { padding:12px 16px; font-size:.8rem; color:#70757a; }

    /* ── Week grid ──────────────────────────────────────────── */
    .cal-week-wrapper  { flex:1; overflow:hidden; display:flex; flex-direction:column; }
    .cal-week-head-row { display:flex; border-bottom:1px solid #dadce0; flex-shrink:0; }
    .cal-week-gutter   { width:52px; flex-shrink:0; }
    .cal-week-day-head { flex:1; text-align:center; padding:8px 4px; font-size:.75rem; }
    .cal-week-day-head .dow  { font-weight:600; color:#70757a; text-transform:uppercase; font-size:.68rem; letter-spacing:.04em; }
    .cal-week-day-head .num  { font-size:1.4rem; font-weight:400; color:#3c4043; line-height:1; width:40px; height:40px;
                               display:flex; align-items:center; justify-content:center; border-radius:50%; margin:0 auto; }
    .cal-week-day-head .num.hoy { background:#1B2A4A; color:#fff; }
    .cal-week-scroll   { flex:1; overflow-y:auto; display:flex; }
    .cal-week-times    { width:52px; flex-shrink:0; }
    .cal-week-time-lbl { height:48px; display:flex; align-items:flex-start; justify-content:flex-end;
                         padding-right:8px; padding-top:-6px; font-size:.65rem; color:#70757a; margin-top:-6px; }
    .cal-week-cols     { flex:1; display:flex; position:relative; }
    .cal-week-col      { flex:1; position:relative; border-left:1px solid #dadce0; min-width:0; }
    .cal-week-hr       { height:48px; border-bottom:1px solid #f1f3f4; }
    .cal-week-hr.media { border-bottom:1px dashed #e8eaed; }
    .cal-week-event    { position:absolute; left:2px; right:2px; border-radius:4px; padding:2px 5px;
                         font-size:.72rem; color:#fff; overflow:hidden; cursor:pointer; z-index:1;
                         text-decoration:none; line-height:1.3; min-height:20px; }
    .cal-week-event:hover { filter:brightness(.92); color:#fff; }
    .cal-week-col.hoy  { background:#fafbff; }
    .cal-allday-row    { display:flex; border-bottom:1px solid #dadce0; flex-shrink:0; min-height:28px; }
    .cal-allday-gutter { width:52px; flex-shrink:0; display:flex; align-items:center; justify-content:flex-end;
                         padding-right:8px; font-size:.6rem; color:#70757a; }
    .cal-allday-cols   { flex:1; display:flex; }
    .cal-allday-col    { flex:1; border-left:1px solid #dadce0; padding:2px; min-height:28px; }
    .cal-allday-chip   { display:block; font-size:.72rem; padding:1px 6px; border-radius:3px; color:#fff;
                         white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-bottom:1px;
                         text-decoration:none; line-height:1.7; }
    .cal-allday-chip:hover { opacity:.85; color:#fff; }
  </style>
<% end %>

<%
  hoy    = Date.current
  locale_dias = %w[L M X J V S D]
  mes_nombres = %w[Enero Febrero Marzo Abril Mayo Junio Julio Agosto Septiembre Octubre Noviembre Diciembre]

  nav_prev = @vista == "week" ? (@fecha - 7.days).iso8601 : (@fecha - 1.month).beginning_of_month.iso8601
  nav_next = @vista == "week" ? (@fecha + 7.days).iso8601 : (@fecha + 1.month).beginning_of_month.iso8601

  titulo_header = @vista == "week" ?
    "#{@dias_semana.first.strftime('%d')} – #{@dias_semana.last.strftime('%d %b')} #{@dias_semana.last.year}" :
    "#{mes_nombres[@fecha.month - 1]} #{@fecha.year}"
%>

<div class="cal-layout">

  <%# ── Sidebar ──────────────────────────────────────────────── %>
  <div class="cal-sidebar">

    <%# Nuevo evento button %>
    <% if puede_gestionar_calendario? %>
      <div style="padding:14px 16px;">
        <%= link_to new_calendario_path(date: hoy, vista: @vista),
              class: "btn btn-sm d-flex align-items-center gap-2",
              style: "background:#fff;border:1px solid #dadce0;border-radius:24px;box-shadow:0 1px 3px rgba(0,0,0,.15);padding:8px 16px;font-size:.85rem;color:#3c4043;" do %>
          <i class="bi bi-plus-lg fs-5" style="color:#1B2A4A;"></i> Crear evento
        <% end %>
      </div>
    <% end %>

    <%# Mini calendar %>
    <div class="mini-cal">
      <div class="mini-cal-head">
        <%= link_to calendario_index_path(fecha: nav_prev, vista: @vista, filtro: @filtro),
              style: "color:inherit;text-decoration:none;" do %><i class="bi bi-chevron-left"></i><% end %>
        <span><%= mes_nombres[@fecha.month - 1] %> <%= @fecha.year %></span>
        <%= link_to calendario_index_path(fecha: nav_next, vista: @vista, filtro: @filtro),
              style: "color:inherit;text-decoration:none;" do %><i class="bi bi-chevron-right"></i><% end %>
      </div>
      <div class="mini-cal-grid">
        <% locale_dias.each do |d| %><div class="mini-cal-dow"><%= d %></div><% end %>
        <% mini_inicio = @fecha.beginning_of_month.beginning_of_week(:monday) %>
        <% mini_fin    = @fecha.end_of_month.end_of_week(:monday) %>
        <% (mini_inicio..mini_fin).each do |d| %>
          <%= link_to d.day,
                calendario_index_path(fecha: d.iso8601, vista: @vista, filtro: @filtro),
                class: [
                  "mini-cal-day",
                  ("today" if d == hoy),
                  ("sel" if @vista == "week" ? @dias_semana&.include?(d) : d.month == @fecha.month),
                  ("otro-mes" if d.month != @fecha.month)
                ].compact.join(" ") %>
        <% end %>
      </div>
    </div>

    <%# Filtro vista %>
    <div class="cal-sb-section">
      <div class="cal-sb-label">Vista</div>
      <%= link_to calendario_index_path(fecha: @fecha.iso8601, vista: @vista, filtro: "logia"),
            class: "cal-filter-btn #{'active' if @filtro == 'logia'}" do %>
        <i class="bi bi-building me-2"></i>Mi Logia
      <% end %>
      <%= link_to calendario_index_path(fecha: @fecha.iso8601, vista: @vista, filtro: "tenant"),
            class: "cal-filter-btn #{'active' if @filtro == 'tenant'}" do %>
        <i class="bi bi-globe2 me-2"></i>Todo el Tenant
      <% end %>
    </div>

    <%# Calendarios visibles %>
    <div class="cal-sb-section">
      <div class="cal-sb-label">Calendarios</div>
      <% @logias_visibles.each do |l| %>
        <div class="cal-legend-item">
          <span class="cal-legend-dot" style="background:<%= l.color_display %>;"></span>
          <span class="text-truncate" title="<%= l.nombre %>"><%= l.nombre_display %></span>
        </div>
      <% end %>
    </div>

    <%# Sync link %>
    <% if puede_gestionar_calendario? %>
      <div class="cal-sb-section">
        <%= link_to calendario_sincronizaciones_path, class: "cal-filter-btn" do %>
          <i class="bi bi-arrow-repeat me-2"></i>Sincronizaciones
          <% if @sync_pendientes > 0 %>
            <span class="badge bg-danger ms-1"><%= @sync_pendientes %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>

  </div><%# /sidebar %>

  <%# ── Main ────────────────────────────────────────────────── %>
  <div class="cal-main">

    <%# Toolbar %>
    <div class="cal-toolbar">
      <%= link_to "Hoy", calendario_index_path(fecha: hoy.iso8601, vista: @vista, filtro: @filtro),
            class: "btn btn-sm btn-outline-secondary", style: "border-radius:4px;" %>

      <%= link_to calendario_index_path(fecha: nav_prev, vista: @vista, filtro: @filtro),
            class: "btn btn-sm btn-link text-secondary p-1" do %>
        <i class="bi bi-chevron-left fs-6"></i>
      <% end %>
      <%= link_to calendario_index_path(fecha: nav_next, vista: @vista, filtro: @filtro),
            class: "btn btn-sm btn-link text-secondary p-1" do %>
        <i class="bi bi-chevron-right fs-6"></i>
      <% end %>

      <span class="cal-toolbar-title"><%= titulo_header %></span>

      <div class="cal-view-btns ms-auto">
        <%= link_to "Mes", calendario_index_path(fecha: @fecha.iso8601, vista: "month", filtro: @filtro),
              class: "cal-view-btn #{'active' if @vista == 'month'}" %>
        <%= link_to "Semana", calendario_index_path(fecha: @fecha.iso8601, vista: "week", filtro: @filtro),
              class: "cal-view-btn #{'active' if @vista == 'week'}" %>
      </div>

      <% if puede_gestionar_calendario? %>
        <%= link_to new_calendario_path(date: hoy, vista: @vista),
              class: "btn btn-sm text-white",
              style: "background:#1B2A4A;border-radius:20px;" do %>
          <i class="bi bi-plus-lg me-1"></i> Nuevo
        <% end %>
      <% end %>
    </div>

    <%# ── MONTH VIEW ─────────────────────────────────────────── %>
    <% if @vista == "month" %>
      <div class="cal-month-head">
        <% locale_dias.each do |d| %>
          <div class="cal-month-dow"><%= d %></div>
        <% end %>
      </div>
      <div class="cal-month" style="flex:1;overflow-y:auto;">
        <div class="cal-month-grid" style="height:100%;">
          <% @semanas.each do |semana| %>
            <% semana.each do |dia| %>
              <% eventos_dia = @eventos_por_dia[dia] || [] %>
              <%
                eventos_json = eventos_dia.map { |e|
                  { id: e.id, titulo: e.titulo, color: e.color,
                    hora: e.todo_el_dia? ? "Todo el día" : e.inicio.strftime("%H:%M"),
                    url: calendario_path(e),
                    recur: e.recurrente? || e.instancia_de_serie? }
                }
                dia_nombres = %w[domingo lunes martes miércoles jueves viernes sábado]
                mes_nombres_es = %w[enero febrero marzo abril mayo junio julio agosto septiembre octubre noviembre diciembre]
                dia_label = "#{dia_nombres[dia.wday].capitalize}, #{dia.day} de #{mes_nombres_es[dia.month-1]}"
              %>
              <div class="cal-day <%= dia.month != @fecha.month ? 'otro-mes' : '' %>"
                   onclick="if(!event.target.closest('a,button'))calDiaClick(event,this)"
                   data-fecha="<%= dia.iso8601 %>"
                   data-label="<%= dia_label %>"
                   data-new-url="<%= puede_gestionar_calendario? ? new_calendario_path(date: dia.iso8601, vista_retorno: 'month') : '' %>"
                   data-eventos="<%= h(eventos_json.to_json) %>">
                <div class="cal-day-num <%= dia.month != @fecha.month ? 'otro-mes' : '' %>">
                  <%= dia.day %>
                </div>
                <% eventos_dia.first(3).each do |e| %>
                  <%= link_to calendario_path(e),
                        class: "cal-chip #{e.todo_el_dia || e.multidia? ? 'todo-dia' : 'timed'}",
                        style: "background-color:#{e.todo_el_dia || e.multidia? ? e.color : 'transparent'};#{e.todo_el_dia || e.multidia? ? '' : "color:#{e.color}!important;"}",
                        title: e.titulo do %>
                    <% unless e.todo_el_dia || e.multidia? %><span style="color:<%= e.color %>;">●</span> <% end %><%= e.todo_el_dia || e.multidia? ? "" : e.inicio.strftime("%H:%M") + " " %><%= e.titulo %>
                  <% end %>
                <% end %>
                <% if eventos_dia.size > 3 %>
                  <span class="cal-mas">+<%= eventos_dia.size - 3 %> más</span>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

    <%# ── WEEK VIEW ──────────────────────────────────────────── %>
    <% else %>
      <div class="cal-week-wrapper">
        <%# All-day row %>
        <div class="cal-allday-row">
          <div class="cal-allday-gutter">todo<br>el día</div>
          <div class="cal-allday-cols">
            <% @dias_semana.each do |dia| %>
              <div class="cal-allday-col">
                <% (@eventos_por_dia[dia] || []).select(&:todo_el_dia).each do |e| %>
                  <%= link_to e.titulo, calendario_path(e),
                        class: "cal-allday-chip",
                        style: "background:#{e.color};",
                        title: e.titulo %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <%# Day headers %>
        <div class="cal-week-head-row">
          <div class="cal-week-gutter"></div>
          <% @dias_semana.each do |dia| %>
            <div class="cal-week-day-head">
              <div class="dow"><%= %w[L M X J V S D][dia.wday == 0 ? 6 : dia.wday - 1] %></div>
              <div class="num <%= dia == hoy ? 'hoy' : '' %>"><%= dia.day %></div>
            </div>
          <% end %>
        </div>

        <%# Time grid %>
        <div class="cal-week-scroll">
          <div class="cal-week-times">
            <% 24.times do |h| %>
              <div class="cal-week-time-lbl">
                <%= h > 0 ? "#{h}:00" : "" %>
              </div>
            <% end %>
          </div>

          <div class="cal-week-cols">
            <% @dias_semana.each do |dia| %>
              <div class="cal-week-col <%= dia == hoy ? 'hoy' : '' %>"
                   <% if puede_gestionar_calendario? %>
                     data-fecha="<%= dia.iso8601 %>"
                     onclick="calWeekColClick(event,this)"
                   <% end %>>
                <% 24.times do |h| %>
                  <div class="cal-week-hr"></div>
                <% end %>
                <%# Timed events %>
                <% (@eventos_por_dia[dia] || []).reject(&:todo_el_dia).each do |e| %>
                  <%
                    dia_inicio = dia.to_time(:utc)
                    ev_inicio  = e.inicio.to_time(:utc)
                    ev_fin     = e.fin.to_time(:utc)
                    start_mins = [(ev_inicio - dia_inicio) / 60.0, 0].max
                    end_mins   = [(ev_fin   - dia_inicio) / 60.0, 24 * 60].min
                    dur_mins   = [end_mins - start_mins, 20].max
                    top_px     = (start_mins * 48.0 / 60.0).round
                    height_px  = [(dur_mins  * 48.0 / 60.0).round, 20].max
                  %>
                  <%= link_to calendario_path(e),
                        class: "cal-week-event",
                        style: "top:#{top_px}px;height:#{height_px}px;background:#{e.color};",
                        title: "#{e.titulo} — #{e.inicio.strftime('%H:%M')} - #{e.fin.strftime('%H:%M')}" do %>
                    <strong><%= e.titulo %></strong>
                    <% if height_px > 32 %>
                      <div><%= e.inicio.strftime("%H:%M") %> – <%= e.fin.strftime("%H:%M") %></div>
                    <% end %>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

  </div><%# /cal-main %>
</div><%# /cal-layout %>


<%# ── Day popover ──────────────────────────────────────────────── %>
<div id="cal-popover">
  <div class="cal-pop-header" id="cal-pop-header"></div>
  <div id="cal-pop-body"></div>
  <div id="cal-pop-footer"></div>
</div>

<script>
  var calNuevoPath = '<%= new_calendario_path %>';

  // ── Scroll week view to current hour on load ─────────────────
  document.addEventListener("turbo:load", function() {
    var scroll = document.querySelector(".cal-week-scroll");
    if (scroll) {
      var now = new Date();
      scroll.scrollTop = Math.max(0, (now.getHours() * 48) - 96);
    }
    document.getElementById('cal-popover').style.display = 'none';
  });

  // ── Month day cell click ─────────────────────────────────────
  function calDiaClick(e, cell) {
    // Close existing popover first
    document.getElementById('cal-popover').style.display = 'none';

    var eventos  = JSON.parse(cell.dataset.eventos || '[]');
    var newUrl   = cell.dataset.newUrl;
    var label    = cell.dataset.label;

    // Empty day + can create → go directly to new event
    if (eventos.length === 0 && newUrl) {
      window.location = newUrl;
      return;
    }

    // Has events → show popover
    showCalPopover(e, cell, label, eventos, newUrl);
  }

  function showCalPopover(e, cell, label, eventos, newUrl) {
    var pop    = document.getElementById('cal-popover');
    var header = document.getElementById('cal-pop-header');
    var body   = document.getElementById('cal-pop-body');
    var footer = document.getElementById('cal-pop-footer');

    // Header
    header.textContent = label;

    // Events list
    if (eventos.length > 0) {
      var html = '';
      eventos.forEach(function(ev) {
        html += '<a href="' + ev.url + '" class="cal-pop-evento">' +
                '<span class="cal-pop-dot" style="background:' + ev.color + ';"></span>' +
                '<span class="cal-pop-hora">' + ev.hora + '</span>' +
                '<span class="cal-pop-titulo">' + escHtml(ev.titulo) + '</span>' +
                (ev.recur ? '<span class="cal-pop-recur" title="Recurrente">↺</span>' : '') +
                '</a>';
      });
      body.innerHTML = html;
    } else {
      body.innerHTML = '';
    }

    // Footer: + Nuevo (only if user can create)
    if (newUrl) {
      footer.innerHTML = '<a href="' + newUrl + '" class="cal-pop-new">' +
                         '<i class="bi bi-plus-lg"></i> Nuevo evento</a>';
      footer.style.display = '';
    } else {
      footer.style.display = 'none';
    }

    // Position: prefer right+below of cell, avoid overflow
    pop.style.display = 'block';
    var rect   = cell.getBoundingClientRect();
    var popW   = pop.offsetWidth  || 240;
    var popH   = pop.offsetHeight || 120;
    var margin = 6;

    var left = rect.right + margin;
    var top  = rect.top;

    // Overflow right → show to the left
    if (left + popW > window.innerWidth - margin) left = rect.left - popW - margin;
    // Overflow bottom → shift up
    if (top + popH > window.innerHeight - margin) top = window.innerHeight - popH - margin;
    // Never negative
    if (left < margin) left = margin;
    if (top  < margin) top  = margin;

    pop.style.left = left + 'px';
    pop.style.top  = top  + 'px';

    // Close on next outside click
    setTimeout(function() {
      document.addEventListener('click', function handler(ev) {
        if (!pop.contains(ev.target)) {
          pop.style.display = 'none';
          document.removeEventListener('click', handler);
        }
      });
    }, 50);
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Week column click → new event at that time ───────────────
  function calWeekColClick(event, col) {
    if (event.target.closest('a, button, .cal-week-event, .cal-allday-chip')) return;
    document.getElementById('cal-popover').style.display = 'none';
    var fecha = col.dataset.fecha;
    var relY  = event.clientY - col.getBoundingClientRect().top;
    var hora  = Math.min(Math.max(Math.floor(relY / 48), 0), 23);
    var min   = (relY % 48) >= 24 ? 30 : 0;
    var pad   = function(n) { return String(n).padStart(2, '0'); };
    var dt    = fecha + 'T' + pad(hora) + ':' + pad(min);
    window.location = calNuevoPath + '?date=' + encodeURIComponent(dt) + '&vista_retorno=week';
  }
</script>
