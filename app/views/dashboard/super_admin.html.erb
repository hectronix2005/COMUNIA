<% content_for(:title, "Dashboard COMUNIA") %>

<div class="container-fluid py-4">
  <%# ---- Page Header ---- %>
  <div class="page-header">
    <div>
      <h1 class="h3 fw-bold"><i class="bi bi-grid-3x3-gap me-2"></i>COMUNIA — Vista Global</h1>
      <p class="text-muted mb-0">Resumen consolidado de todos los tenants</p>
    </div>
    <div class="text-muted">
      <i class="bi bi-calendar3 me-1"></i>
      <%= l(Date.current, format: :long) %>
    </div>
  </div>

  <%# ---- Stat Cards ---- %>
  <div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
      <%= link_to miembros_path, class: "text-decoration-none" do %>
        <div class="card stat-card stat-card-primary" style="cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;" onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.2)'" onmouseleave="this.style.transform='';this.style.boxShadow=''">
          <div class="card-body d-flex align-items-center">
            <div class="stat-icon bg-white bg-opacity-15 text-white">
              <i class="bi bi-people-fill"></i>
            </div>
            <div class="ms-3">
              <h3 class="mb-0 fw-bold"><%= @total_miembros %></h3>
              <span class="text-white-50 small text-uppercase">Total Miembros</span>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="col-xl-3 col-md-6">
      <%= link_to cobros_path(estado: "pendiente"), class: "text-decoration-none" do %>
        <div class="card stat-card stat-card-warning" style="cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;" onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.2)'" onmouseleave="this.style.transform='';this.style.boxShadow=''">
          <div class="card-body d-flex align-items-center">
            <div class="stat-icon bg-white bg-opacity-15 text-white">
              <i class="bi bi-clock-history"></i>
            </div>
            <div class="ms-3">
              <h3 class="mb-0 fw-bold"><%= @total_cobros_pendientes %></h3>
              <span class="text-white-50 small text-uppercase">Cobros Pendientes</span>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="col-xl-3 col-md-6">
      <%= link_to cobros_path(estado: "soporte_adjunto"), class: "text-decoration-none" do %>
        <div class="card stat-card stat-card-info" style="cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;" onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.2)'" onmouseleave="this.style.transform='';this.style.boxShadow=''">
          <div class="card-body d-flex align-items-center">
            <div class="stat-icon bg-white bg-opacity-15 text-white">
              <i class="bi bi-paperclip"></i>
            </div>
            <div class="ms-3">
              <h3 class="mb-0 fw-bold"><%= @total_soporte_adjunto %></h3>
              <span class="text-white-50 small text-uppercase">Soportes por Validar</span>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="col-xl-3 col-md-6">
      <%= link_to cobros_path(estado: "pagado"), class: "text-decoration-none" do %>
        <div class="card stat-card stat-card-success" style="cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;" onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.2)'" onmouseleave="this.style.transform='';this.style.boxShadow=''">
          <div class="card-body d-flex align-items-center">
            <div class="stat-icon bg-white bg-opacity-15 text-white">
              <i class="bi bi-check-circle-fill"></i>
            </div>
            <div class="ms-3">
              <h3 class="mb-0 fw-bold"><%= @total_pagados %></h3>
              <span class="text-white-50 small text-uppercase">Pagos Realizados</span>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="col-xl-3 col-md-6">
      <%= link_to cobros_path(estado: "vencido"), class: "text-decoration-none" do %>
        <div class="card stat-card stat-card-danger" style="cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;" onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.2)'" onmouseleave="this.style.transform='';this.style.boxShadow=''">
          <div class="card-body d-flex align-items-center">
            <div class="stat-icon bg-white bg-opacity-15 text-white">
              <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div class="ms-3">
              <h3 class="mb-0 fw-bold"><%= @total_vencidos %></h3>
              <span class="text-white-50 small text-uppercase">Vencidos</span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ---- Resumen por Logia ---- %>
  <div class="card mb-4">
    <div class="card-header bg-primary text-white">
      <h5 class="card-title mb-0 text-white"><i class="bi bi-building me-2"></i>Resumen por Tenant</h5>
    </div>
    <div class="card-body p-0">
      <div class="table-rounded">
        <div class="table-responsive">
          <table class="table table-striped table-hover mb-0">
            <thead>
              <tr>
                <th>Logia</th>
                <th>Codigo</th>
                <th class="text-end">Pendientes</th>
                <th class="text-end">Soporte Adjunto</th>
                <th class="text-end">Pagados</th>
                <th class="text-end">Vencidos</th>
                <th style="min-width: 180px;">Distribucion</th>
              </tr>
            </thead>
            <tbody>
              <% @resumen_por_logia.each do |resumen| %>
                <% total = resumen[:pendientes] + resumen[:soporte_adjunto] + resumen[:pagados] + resumen[:vencidos] %>
                <tr>
                  <td>
                    <%= link_to logia_path(resumen[:logia]), class: "text-decoration-none fw-semibold" do %>
                      <i class="bi bi-building me-1 text-muted"></i><%= resumen[:logia].nombre %>
                    <% end %>
                  </td>
                  <td><span class="badge bg-secondary"><%= resumen[:logia].codigo %></span></td>
                  <td class="text-end"><span class="badge badge-pendiente"><%= resumen[:pendientes] %></span></td>
                  <td class="text-end"><span class="badge badge-soporte"><%= resumen[:soporte_adjunto] %></span></td>
                  <td class="text-end"><span class="badge badge-pagado"><%= resumen[:pagados] %></span></td>
                  <td class="text-end"><span class="badge badge-vencido"><%= resumen[:vencidos] %></span></td>
                  <td>
                    <% if total > 0 %>
                      <div class="progress" style="height: 8px;" title="Pagados: <%= resumen[:pagados] %> | Pendientes: <%= resumen[:pendientes] %> | Soporte: <%= resumen[:soporte_adjunto] %> | Vencidos: <%= resumen[:vencidos] %>">
                        <div class="progress-bar bg-success" style="width: <%= (resumen[:pagados].to_f / total * 100).round(1) %>%"></div>
                        <div class="progress-bar bg-warning" style="width: <%= (resumen[:pendientes].to_f / total * 100).round(1) %>%"></div>
                        <div class="progress-bar bg-info" style="width: <%= (resumen[:soporte_adjunto].to_f / total * 100).round(1) %>%"></div>
                        <div class="progress-bar bg-danger" style="width: <%= (resumen[:vencidos].to_f / total * 100).round(1) %>%"></div>
                      </div>
                    <% else %>
                      <span class="text-muted small">Sin cobros</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <%# ---- Cobros Pendientes de Validacion ---- %>
  <div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
      <h5 class="card-title mb-0">
        <i class="bi bi-hourglass-split me-2"></i>Pendientes de Validacion
      </h5>
      <span class="badge bg-info"><%= @cobros_recientes.size %></span>
    </div>
    <div class="card-body p-0">
      <% if @cobros_recientes.any? %>
        <div class="table-rounded">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr>
                  <th>Miembro</th>
                  <th>Logia</th>
                  <th>Periodo</th>
                  <th class="text-end">Monto</th>
                  <th>Actualizado</th>
                  <th class="text-center">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% @cobros_recientes.each do |cobro| %>
                  <tr>
                    <td class="fw-semibold"><%= cobro.miembro.nombre_completo %></td>
                    <td><%= cobro.miembro.logia.nombre %></td>
                    <td><%= cobro.periodo_cobro.nombre %></td>
                    <td class="text-end fw-semibold"><%= pesos(cobro.monto) %></td>
                    <td>
                      <small class="text-muted" title="<%= l(cobro.updated_at, format: :long) %>">
                        <i class="bi bi-clock me-1"></i>hace <%= time_ago_in_words(cobro.updated_at) %>
                      </small>
                    </td>
                    <td class="text-center">
                      <%= link_to validar_cobro_path(cobro), class: "btn btn-sm btn-primary" do %>
                        <i class="bi bi-check2-square me-1"></i>Validar
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% else %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="bi bi-check-circle"></i>
          </div>
          <p class="empty-state-title">Todo al dia</p>
          <p class="empty-state-text">No hay cobros pendientes de validacion.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
