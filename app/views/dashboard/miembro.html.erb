<% content_for(:title, "Mi Panel") %>

<div class="container-fluid py-4">
  <%# ---- Page Header ---- %>
  <div class="page-header">
    <div>
      <h1 class="h3 fw-bold">Bienvenido, <%= current_user.nombre %></h1>
      <p class="text-muted mb-0">Tu panel personal</p>
    </div>
    <div class="text-muted">
      <i class="bi bi-calendar3 me-1"></i>
      <%= l(Date.current, format: :long) %>
    </div>
  </div>

  <%# ---- Alert for Vencidos ---- %>
  <% if @vencidos.any? %>
    <div class="alert alert-danger d-flex align-items-center mb-4">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      Tienes <%= @vencidos.count %> cobro(s) vencido(s). Por favor regulariza tu situacion.
    </div>
  <% end %>

  <%# ---- Stat Cards ---- %>
  <div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
      <div class="card stat-card stat-card-warning">
        <div class="card-body d-flex align-items-center">
          <div class="stat-icon bg-white bg-opacity-15 text-white">
            <i class="bi bi-clock-history"></i>
          </div>
          <div class="ms-3">
            <h3 class="mb-0 fw-bold"><%= @pendientes.count %></h3>
            <span class="text-white-50 small text-uppercase">Pendientes</span>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6">
      <div class="card stat-card stat-card-info">
        <div class="card-body d-flex align-items-center">
          <div class="stat-icon bg-white bg-opacity-15 text-white">
            <i class="bi bi-paperclip"></i>
          </div>
          <div class="ms-3">
            <h3 class="mb-0 fw-bold"><%= @soporte_adjunto.count %></h3>
            <span class="text-white-50 small text-uppercase">Soporte Enviado</span>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6">
      <div class="card stat-card stat-card-success">
        <div class="card-body d-flex align-items-center">
          <div class="stat-icon bg-white bg-opacity-15 text-white">
            <i class="bi bi-check-circle-fill"></i>
          </div>
          <div class="ms-3">
            <h3 class="mb-0 fw-bold"><%= @pagados.count %></h3>
            <span class="text-white-50 small text-uppercase">Pagados</span>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6">
      <div class="card stat-card stat-card-danger">
        <div class="card-body d-flex align-items-center">
          <div class="stat-icon bg-white bg-opacity-15 text-white">
            <i class="bi bi-exclamation-triangle-fill"></i>
          </div>
          <div class="ms-3">
            <h3 class="mb-0 fw-bold"><%= @vencidos.count %></h3>
            <span class="text-white-50 small text-uppercase">Vencidos</span>
          </div>
        </div>
      </div>
    </div>
  </div>

    <%# ---- Módulo Red Social ---- %>
  <div class="card mb-4 border-0 shadow-sm">
    <div class="card-header d-flex align-items-center gap-2 py-3"
         style="background:linear-gradient(135deg,#064e3b 0%,#065f46 100%);color:#fff;border-radius:.5rem .5rem 0 0;cursor:pointer;"
         data-bs-toggle="collapse" data-bs-target="#miembroRedSocialBody" aria-expanded="false">
      <i class="bi bi-people-fill fs-4"></i>
      <div class="flex-grow-1">
        <h5 class="mb-0 fw-bold">Red Social</h5>
        <small class="opacity-75">Chat · Calendario</small>
      </div>
      <i class="bi bi-chevron-down ms-auto" id="miembroRedSocialChevron" style="transition:transform .25s"></i>
    </div>
    <div class="collapse" id="miembroRedSocialBody">
      <div class="card-body p-4" style="background:#031a10;color:#fff">
        <div class="d-flex gap-2 flex-wrap">
          <%= link_to chat_path, class: "btn btn-outline-light" do %>
            <i class="bi bi-chat-dots me-1"></i>Chat
          <% end %>
          <%= link_to calendario_index_path, class: "btn btn-outline-light" do %>
            <i class="bi bi-calendar3 me-1"></i>Calendario
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ---- Módulo Biblioteca ---- %>
  <div class="card mb-4 border-0 shadow-sm">
    <div class="card-header d-flex align-items-center gap-2 py-3"
         style="background:linear-gradient(135deg,#2e1065 0%,#4c1d95 100%);color:#fff;border-radius:.5rem .5rem 0 0;cursor:pointer;"
         data-bs-toggle="collapse" data-bs-target="#miembroBibliotecaBody" aria-expanded="false">
      <i class="bi bi-book-half fs-4"></i>
      <div class="flex-grow-1">
        <h5 class="mb-0 fw-bold">Biblioteca</h5>
        <small class="opacity-75">Planchas (<%= @biblioteca_planchas_count || 0 %>) · Libros (<%= @biblioteca_libros_count || 0 %>)</small>
      </div>
      <i class="bi bi-chevron-down ms-auto" id="miembroBibliotecaChevron" style="transition:transform .25s"></i>
    </div>
    <div class="collapse" id="miembroBibliotecaBody">
      <div class="card-body p-4" style="background:#150a30;color:#fff">
        <div class="d-flex gap-2 flex-wrap">
          <%= link_to biblioteca_planchas_path, class: "btn btn-outline-light" do %>
            <i class="bi bi-file-earmark-text me-1"></i>Planchas
          <% end %>
          <%= link_to biblioteca_libros_path, class: "btn btn-outline-light" do %>
            <i class="bi bi-book me-1"></i>Libros
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ---- Módulo Hospitalia ---- %>
  <div class="card mb-4 border-0 shadow-sm">
    <div class="card-header d-flex align-items-center gap-2 py-3"
         style="background:linear-gradient(135deg,#7f1d1d 0%,#991b1b 100%);color:#fff;border-radius:.5rem .5rem 0 0;cursor:pointer;"
         data-bs-toggle="collapse" data-bs-target="#miembroHospitaliaBody" aria-expanded="false">
      <i class="bi bi-heart-pulse fs-4"></i>
      <div class="flex-grow-1">
        <h5 class="mb-0 fw-bold">Hospitalia</h5>
        <small class="opacity-75">Fondo de apoyo mutuo · Cumpleaños</small>
      </div>
      <i class="bi bi-chevron-down ms-auto" id="miembroHospitaliaChevron" style="transition:transform .25s"></i>
    </div>
    <div class="collapse" id="miembroHospitaliaBody">
      <div class="card-body p-4" style="background:#130303;color:#fff">
        <div class="d-flex gap-2 flex-wrap">
          <%= link_to hospitalia_path, class: "btn btn-outline-light" do %>
            <i class="bi bi-speedometer2 me-1"></i>Resumen
          <% end %>
          <%= link_to hospitalia_cumpleanos_path, class: "btn btn-outline-light" do %>
            <i class="bi bi-balloon-heart me-1"></i>Cumpleaños
          <% end %>
          <% if current_user.miembro %>
            <%= link_to hospitalia_familiares_path(miembro_id: current_user.miembro.id), class: "btn btn-outline-light" do %>
              <i class="bi bi-people me-1"></i>Mi Familia
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ---- Módulo Negocios ---- %>
  <div class="card mb-4 border-0 shadow-sm">
    <div class="card-header d-flex align-items-center gap-2 py-3"
         style="background:linear-gradient(135deg,#0c2340 0%,#1e3a5f 100%);color:#fff;border-radius:.5rem .5rem 0 0;cursor:pointer;"
         data-bs-toggle="collapse" data-bs-target="#miembroNegociosBody" aria-expanded="false">
      <i class="bi bi-briefcase fs-4"></i>
      <div class="flex-grow-1">
        <h5 class="mb-0 fw-bold">Negocios</h5>
        <small class="opacity-75"><%= @negocios_count || 0 %> anuncios activos en el tenant</small>
      </div>
      <i class="bi bi-chevron-down ms-auto" id="miembroNegociosChevron" style="transition:transform .25s"></i>
    </div>
    <div class="collapse" id="miembroNegociosBody">
      <div class="card-body p-4" style="background:#040c18;color:#fff">
        <div class="d-flex gap-2 flex-wrap">
          <%= link_to negocios_path, class: "btn btn-outline-light" do %>
            <i class="bi bi-grid me-1"></i>Ver Marketplace
          <% end %>
          <%= link_to new_negocio_path, class: "btn btn-light" do %>
            <i class="bi bi-plus-lg me-1"></i>Publicar Anuncio
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      [
        ['miembroRedSocialBody',   'miembroRedSocialChevron'],
        ['miembroBibliotecaBody',  'miembroBibliotecaChevron'],
        ['miembroHospitaliaBody',  'miembroHospitaliaChevron'],
        ['miembroNegociosBody',    'miembroNegociosChevron']
      ].forEach(function(pair) {
        var el = document.getElementById(pair[0]);
        var ch = document.getElementById(pair[1]);
        if (el && ch) {
          el.addEventListener('show.bs.collapse', function() { ch.style.transform = 'rotate(180deg)'; });
          el.addEventListener('hide.bs.collapse', function() { ch.style.transform = 'rotate(0deg)'; });
        }
      });
    })();
  </script>

<%# ---- Tabla de Cobros ---- %>
  <% cobros_seleccionables = @cobros.select(&:puede_adjuntar_soporte?) %>

  <div class="card">
    <div class="card-header">
      <h5 class="card-title mb-0"><i class="bi bi-receipt me-2"></i>Mis Cobros</h5>
    </div>
    <div class="card-body p-0">
      <% if @cobros.any? %>
        <%= form_tag adjuntar_soporte_multiple_cobros_path, method: :get, id: "bulk-soporte-form" do %>
          <div class="table-rounded">
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead>
                  <tr>
                    <th>Periodo</th>
                    <th class="text-end">Monto</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">RC</th>
                    <th class="text-center">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% @cobros.each do |cobro| %>
                    <tr id="row-cobro-<%= cobro.id %>" class="<%= 'table-row-selected' if false %>">
                      <td class="fw-semibold"><%= cobro.periodo_cobro.nombre %></td>
                      <td class="text-end fw-semibold"><%= pesos(cobro.monto) %></td>
                      <td class="text-center"><%= render "shared/estado_badge", estado: cobro.estado %></td>
                      <td class="text-center"><%= cobro.pago&.numero_rc || "-" %></td>
                      <td class="text-center">
                        <% if cobro.puede_adjuntar_soporte? %>
                          <div class="d-flex align-items-center justify-content-center gap-2">
                            <input type="checkbox" name="cobro_ids[]" value="<%= cobro.id %>"
                                   class="form-check-input cobro-checkbox m-0"
                                   data-monto="<%= cobro.monto.to_i %>"
                                   data-row="row-cobro-<%= cobro.id %>"
                                   id="chk-<%= cobro.id %>"
                                   style="cursor: pointer;">
                            <label for="chk-<%= cobro.id %>" class="btn btn-sm btn-outline-success mb-0 cobro-label" style="cursor: pointer;">
                              <i class="bi bi-check2-square me-1"></i>Pagar
                            </label>
                          </div>
                        <% elsif cobro.soporte_adjunto? %>
                          <span class="badge bg-info-subtle text-info">
                            <i class="bi bi-hourglass-split me-1"></i>En validacion
                          </span>
                        <% elsif cobro.pagado? && cobro.pago.present? %>
                          <%= link_to recibo_reportes_path(pago_id: cobro.pago.id), class: "btn btn-sm btn-outline-success" do %>
                            <i class="bi bi-file-earmark-text me-1"></i>Ver Recibo
                          <% end %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="bi bi-inbox"></i>
          </div>
          <p class="empty-state-title">No tienes cobros registrados</p>
          <p class="empty-state-text">Cuando se generen cobros para tu periodo, apareceran aqui.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# ---- Barra fija inferior de pago ---- %>
<% if cobros_seleccionables.any? %>
<div id="pay-bar" class="pay-bar" style="display: none;">
  <div class="container-fluid d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center gap-3">
      <div class="pay-bar-icon">
        <i class="bi bi-cart-check"></i>
      </div>
      <div>
        <span class="text-white-50 small">Seleccionados:</span>
        <strong class="text-white ms-1"><span id="selected-count">0</span> mes(es)</strong>
      </div>
      <div class="vr bg-white-50 opacity-25 mx-2" style="height: 30px;"></div>
      <div>
        <span class="text-white-50 small">Total a pagar:</span>
        <strong class="text-white fs-5 ms-1" id="selected-total">$0</strong>
      </div>
    </div>
    <div class="d-flex align-items-center gap-2">
      <button type="button" id="btn-clear-selection" class="btn btn-outline-light btn-sm">
        <i class="bi bi-x-lg me-1"></i>Limpiar
      </button>
      <button type="submit" form="bulk-soporte-form" class="btn btn-light btn-sm fw-semibold px-4">
        <i class="bi bi-cloud-upload me-1"></i>Adjuntar Comprobante por <span id="bar-total-btn">$0</span>
      </button>
    </div>
  </div>
</div>
<% end %>

<style>
  .pay-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(135deg, #1B2A4A 0%, #2a4070 100%);
    padding: 0.75rem 1rem;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.25);
    z-index: 1050;
    animation: slideUp 0.3s ease;
  }
  @keyframes slideUp {
    from { transform: translateY(100%); opacity: 0; }
    to   { transform: translateY(0); opacity: 1; }
  }
  .pay-bar-icon {
    width: 38px;
    height: 38px;
    background: rgba(255,255,255,0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C9A84C;
    font-size: 1.1rem;
  }
  tr.table-row-selected {
    background-color: #e8f5e9 !important;
  }
  tr.table-row-selected td {
    background-color: #e8f5e9 !important;
  }
  .cobro-checkbox:checked + .cobro-label {
    background-color: #198754;
    border-color: #198754;
    color: #fff;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var checkboxes = document.querySelectorAll(".cobro-checkbox");
    var payBar = document.getElementById("pay-bar");
    var selectedCount = document.getElementById("selected-count");
    var selectedTotal = document.getElementById("selected-total");
    var barTotalBtn = document.getElementById("bar-total-btn");
    var btnClear = document.getElementById("btn-clear-selection");

    if (checkboxes.length === 0) return;

    function formatPesos(n) {
      return "$" + n.toLocaleString("es-CO");
    }

    function updatePayBar() {
      var checked = document.querySelectorAll(".cobro-checkbox:checked");
      var count = checked.length;
      var total = 0;
      checked.forEach(function(cb) { total += parseInt(cb.dataset.monto, 10); });

      // Highlight rows
      checkboxes.forEach(function(cb) {
        var row = document.getElementById(cb.dataset.row);
        if (row) {
          if (cb.checked) {
            row.classList.add("table-row-selected");
          } else {
            row.classList.remove("table-row-selected");
          }
        }
      });

      if (count > 0) {
        payBar.style.display = "block";
        selectedCount.textContent = count;
        selectedTotal.textContent = formatPesos(total);
        barTotalBtn.textContent = formatPesos(total);
      } else {
        payBar.style.display = "none";
      }
    }

    // Toggle via checkbox or label click
    checkboxes.forEach(function(cb) {
      cb.addEventListener("change", updatePayBar);
    });

    // Clear selection button
    if (btnClear) {
      btnClear.addEventListener("click", function() {
        checkboxes.forEach(function(cb) { cb.checked = false; });
        updatePayBar();
      });
    }
  });
</script>
