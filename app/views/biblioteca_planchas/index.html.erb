<% content_for(:title, "Planchas") %>

<div class="container py-4">
  <div class="mb-3">
    <%= link_to dashboard_path, class: "btn btn-sm btn-link text-muted ps-0" do %>
      <i class="bi bi-arrow-left me-1"></i>Volver
    <% end %>
  </div>

  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h4 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text me-2"></i>Planchas</h4>
      <p class="text-muted small mb-0">Documentos por grado masónico</p>
    </div>
    <% if action_name == "index" %>
      <% grado_usuario = current_user.miembro&.grado %>
      <% if controller.send(:puede_gestionar?) %>
        <%= link_to new_biblioteca_plancha_path, class: "btn btn-primary btn-sm" do %>
          <i class="bi bi-plus-lg me-1"></i>Nueva Plancha
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Filtro por grado %>
  <div class="mb-4 d-flex gap-2 flex-wrap">
    <%= link_to "Todos", biblioteca_planchas_path,
          class: "btn btn-sm #{@grado_filtro.nil? ? 'btn-dark' : 'btn-outline-secondary'}" %>
    <% BibliotecaPlancha::GRADOS.each do |g| %>
      <%= link_to g, biblioteca_planchas_path(grado: g),
            class: "btn btn-sm #{@grado_filtro == g ? 'btn-dark' : 'btn-outline-secondary'}" %>
    <% end %>
  </div>

  <% if @planchas.empty? %>
    <div class="text-center text-muted py-5">
      <i class="bi bi-file-earmark-text display-4 opacity-25"></i>
      <p class="mt-3">No hay planchas disponibles<% if @grado_filtro.present? %> para <%= @grado_filtro %><% end %>.</p>
    </div>
  <% else %>
    <%# Group by grado %>
    <% @planchas.group_by(&:grado).each do |grado, grupo| %>
      <h6 class="text-muted text-uppercase small fw-bold mb-3 border-bottom pb-1">
        <i class="bi bi-bookmark-star me-1"></i><%= grado %>
      </h6>
      <div class="row g-3 mb-4">
        <% grupo.each do |plancha| %>
          <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between">
                  <div class="flex-grow-1">
                    <h6 class="mb-1 fw-semibold">
                      <%= link_to plancha.titulo, biblioteca_plancha_path(plancha),
                            class: "text-decoration-none text-dark stretched-link" %>
                    </h6>
                    <% if plancha.autor.present? %>
                      <div class="text-muted small"><i class="bi bi-person me-1"></i><%= plancha.autor %></div>
                    <% end %>
                    <% if plancha.anio.present? %>
                      <div class="text-muted small"><i class="bi bi-calendar me-1"></i><%= plancha.anio %></div>
                    <% end %>
                  </div>
                  <% if plancha.documento.attached? %>
                    <i class="bi bi-paperclip text-muted ms-2"></i>
                  <% end %>
                </div>
                <% if plancha.descripcion.present? %>
                  <p class="text-muted small mt-2 mb-0" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
                    <%= plancha.descripcion %>
                  </p>
                <% end %>
              </div>
              <div class="card-footer bg-transparent border-0 pt-0">
                <small class="text-muted">Por <%= plancha.user.nombre_completo %></small>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
