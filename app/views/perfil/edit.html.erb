<% content_for(:title, "Mi perfil") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h4 mb-0"><i class="bi bi-person-circle me-2"></i>Mi perfil</h1>
  <%= link_to chat_path, class: "btn btn-outline-secondary btn-sm" do %>
    <i class="bi bi-arrow-left me-1"></i>Volver al chat
  <% end %>
</div>

<div class="card card-body" style="max-width: 560px;">
  <% if @user.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <dl class="row small text-muted mb-3">
    <dt class="col-sm-4">Nombre registrado</dt>
    <dd class="col-sm-8"><%= @user.nombre_completo %></dd>
    <dt class="col-sm-4">Usuario</dt>
    <dd class="col-sm-8"><%= @user.username %></dd>
  </dl>

  <%= form_with model: @user, url: perfil_path, method: :patch, local: true do |f| %>
    <div class="mb-3">
      <%= f.label :nombre_visible, "Nombre visible en el chat", class: "form-label fw-semibold" %>
      <%= f.text_field :nombre_visible,
            class: "form-control",
            placeholder: @user.nombre_corto,
            maxlength: 60 %>
      <div class="form-text">
        Así te verán los demás en el chat. Si lo dejas vacío, se mostrará
        <strong><%= @user.nombre_corto %></strong> (tu primer nombre y apellido).
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit "Guardar", class: "btn btn-primary" %>
      <%= link_to "Cancelar", chat_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
