<% content_for(:title, "Cumpleaños – Hospitalia") %>

<div class="container py-4">
  <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <%= link_to hospitalia_path, class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-arrow-left"></i>
    <% end %>
    <div>
      <h4 class="mb-0 fw-bold"><i class="bi bi-balloon-heart text-warning me-2"></i>Cumpleaños</h4>
      <p class="text-muted small mb-0">
        <%= pluralize(@proximos.size, "cumpleaños", plural: "cumpleaños") %>
        <% if @rango.positive? %>en los próximos <%= @rango %> días<% else %>registrados<% end %>
      </p>
    </div>
  </div>

  <%# ── Filtros de rango ──────────────────────────────────── %>
  <div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
    <div class="btn-group btn-group-sm" role="group">
      <%= link_to "Todos",     hospitalia_cumpleanos_path,              class: "btn #{@rango.zero? ? 'btn-dark' : 'btn-outline-secondary'}" %>
      <%= link_to "Hoy/Mes",   hospitalia_cumpleanos_path(rango: 30),   class: "btn #{@rango == 30 ? 'btn-dark' : 'btn-outline-secondary'}" %>
      <%= link_to "90 días",   hospitalia_cumpleanos_path(rango: 90),   class: "btn #{@rango == 90 ? 'btn-dark' : 'btn-outline-secondary'}" %>
      <%= link_to "Semestre",  hospitalia_cumpleanos_path(rango: 180),  class: "btn #{@rango == 180 ? 'btn-dark' : 'btn-outline-secondary'}" %>
    </div>

    <% miembro_actual = current_user.miembro %>
    <% if miembro_actual %>
      <%= link_to hospitalia_familiares_path(miembro_id: miembro_actual.id),
            class: "btn btn-sm btn-outline-primary ms-auto" do %>
        <i class="bi bi-people me-1"></i>Mis familiares
      <% end %>
    <% end %>
  </div>

  <% if @proximos.empty? %>
    <div class="text-center text-muted py-5">
      <i class="bi bi-balloon-heart display-4 opacity-25"></i>
      <p class="mt-3">No hay cumpleaños registrados<% if @rango.positive? %> en los próximos <%= @rango %> días<% end %>.</p>
      <p class="small">Asegúrate de registrar las fechas de nacimiento de los miembros y sus familiares.</p>
    </div>
  <% else %>
    <%# Agrupar por mes del cumpleaños para navegación rápida %>
    <% agrupados = @proximos.group_by { |p| p[:fecha].beginning_of_month } %>

    <% agrupados.each do |mes, items| %>
      <div class="mb-4">
        <h6 class="text-muted text-uppercase fw-bold small mb-2 border-bottom pb-1">
          <i class="bi bi-calendar-event me-1"></i>
          <%= I18n.l(mes, format: "%B %Y").capitalize rescue mes.strftime("%B %Y") %>
          <span class="badge bg-secondary ms-1"><%= items.size %></span>
        </h6>

        <div class="list-group shadow-sm">
          <% items.each do |p| %>
            <div class="list-group-item d-flex align-items-center gap-3 py-2">
              <%# Fecha badge compacto %>
              <div class="text-center rounded d-flex flex-column align-items-center justify-content-center flex-shrink-0 <%= p[:dias] == 0 ? 'bg-warning text-white' : (p[:dias] <= 7 ? 'bg-danger text-white' : (p[:dias] <= 30 ? 'bg-info bg-opacity-25' : 'bg-light')) %>"
                   style="width:46px;height:46px;line-height:1;">
                <span class="fw-bold" style="font-size:1.05rem;"><%= p[:fecha].strftime("%d") %></span>
                <span class="text-uppercase" style="font-size:.65rem;"><%= I18n.l(p[:fecha], format: "%b").downcase rescue p[:fecha].strftime("%b").downcase %></span>
              </div>

              <%# Nombre + info %>
              <div class="flex-grow-1 min-w-0">
                <div class="fw-semibold text-truncate"><%= p[:nombre] %></div>
                <div class="text-muted small text-truncate">
                  <% if p[:tipo] == "Familiar" %>
                    <i class="bi bi-people me-1"></i><%= p[:parentesco] %> de <%= p[:miembro].user.nombre_completo %>
                  <% else %>
                    <i class="bi bi-person-badge me-1"></i>Miembro
                  <% end %>
                </div>
              </div>

              <%# Días restantes %>
              <div class="text-end small flex-shrink-0" style="min-width:70px;">
                <% if p[:dias] == 0 %>
                  <span class="badge bg-warning"><i class="bi bi-balloon-heart-fill me-1"></i>¡Hoy!</span>
                <% elsif p[:dias] <= 7 %>
                  <span class="badge bg-danger"><%= p[:dias] %> <%= p[:dias] == 1 ? "día" : "días" %></span>
                <% else %>
                  <span class="text-muted"><%= p[:dias] %> días</span>
                <% end %>
              </div>

              <%# Acción %>
              <% if p[:tipo] == "Familiar" %>
                <%= link_to hospitalia_enviar_felicitacion_path(miembro_id: p[:miembro].id),
                      data: { turbo_method: :post, turbo_confirm: "¿Enviar felicitación a #{p[:nombre]}?" },
                      class: "btn btn-sm btn-outline-warning flex-shrink-0" do %>
                  <i class="bi bi-send"></i><span class="d-none d-md-inline ms-1">Felicitar</span>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
