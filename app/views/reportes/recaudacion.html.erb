<% content_for(:title, "Reporte de Recaudación") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Reporte de Recaudaci&oacute;n</h1>
  <%= link_to "Exportar Excel", recaudacion_reportes_path(format: :xlsx, fecha_desde: params[:fecha_desde], fecha_hasta: params[:fecha_hasta], logia_id: params[:logia_id]), class: "btn btn-success" %>
</div>

<%
  mes_actual_desde   = Date.current.beginning_of_month
  mes_actual_hasta   = Date.current.end_of_month
  mes_anterior_desde = (Date.current - 1.month).beginning_of_month
  mes_anterior_hasta = (Date.current - 1.month).end_of_month
  anio_actual_desde  = Date.current.beginning_of_year
  anio_actual_hasta  = Date.current.end_of_year

  activo_mes_actual   = @fecha_desde == mes_actual_desde   && @fecha_hasta == mes_actual_hasta
  activo_mes_anterior = @fecha_desde == mes_anterior_desde && @fecha_hasta == mes_anterior_hasta
  activo_anio_actual  = @fecha_desde == anio_actual_desde  && @fecha_hasta == anio_actual_hasta

  meses_select = (0..23).map { |i| Date.current - i.months }.map do |d|
    [I18n.l(d, format: "%B %Y").capitalize, "#{d.beginning_of_month}|#{d.end_of_month}"]
  end
  mes_seleccionado = "#{@fecha_desde}|#{@fecha_hasta}"
%>

<%= form_tag recaudacion_reportes_path, method: :get, id: "form-recaudacion" do %>
  <%# ── Accesos rápidos ──────────────────────────────────── %>
  <div class="card mb-3">
    <div class="card-body py-2">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <span class="text-muted small fw-semibold me-1">Período rápido:</span>

        <button type="button" class="btn btn-sm <%= activo_mes_actual ? 'btn-primary' : 'btn-outline-primary' %>"
                onclick="setFechas('<%= mes_actual_desde %>', '<%= mes_actual_hasta %>')">
          Mes actual
        </button>
        <button type="button" class="btn btn-sm <%= activo_mes_anterior ? 'btn-secondary' : 'btn-outline-secondary' %>"
                onclick="setFechas('<%= mes_anterior_desde %>', '<%= mes_anterior_hasta %>')">
          Mes anterior
        </button>
        <button type="button" class="btn btn-sm <%= activo_anio_actual ? 'btn-dark' : 'btn-outline-dark' %>"
                onclick="setFechas('<%= anio_actual_desde %>', '<%= anio_actual_hasta %>')">
          Este año
        </button>

        <select class="form-select form-select-sm w-auto" id="selector-mes"
                onchange="seleccionarMes(this.value)">
          <option value="">— Seleccionar mes —</option>
          <% meses_select.each do |label, valor| %>
            <option value="<%= valor %>" <%= 'selected' if mes_seleccionado == valor %>><%= label %></option>
          <% end %>
        </select>
      </div>
    </div>
  </div>

  <%# ── Filtros avanzados ──────────────────────────────────── %>
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <label for="fecha_desde" class="form-label">Desde</label>
      <%= date_field_tag :fecha_desde, params[:fecha_desde] || @fecha_desde, class: "form-control", id: "fecha_desde" %>
    </div>
    <div class="col-md-3">
      <label for="fecha_hasta" class="form-label">Hasta</label>
      <%= date_field_tag :fecha_hasta, params[:fecha_hasta] || @fecha_hasta, class: "form-control", id: "fecha_hasta" %>
    </div>
    <div class="col-md-3">
      <label for="logia_id" class="form-label">Logia</label>
      <%= select_tag :logia_id,
            options_from_collection_for_select(@logias, :id, :nombre, params[:logia_id]),
            include_blank: "-- Todas las Logias --",
            class: "form-select" %>
    </div>
    <div class="col-md-3 d-flex align-items-end gap-2">
      <%= submit_tag "Filtrar", class: "btn btn-primary" %>
      <%= link_to "Limpiar", recaudacion_reportes_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
<% end %>

<script>
  function setFechas(desde, hasta) {
    document.getElementById('fecha_desde').value = desde;
    document.getElementById('fecha_hasta').value = hasta;
    document.getElementById('form-recaudacion').requestSubmit();
  }
  function seleccionarMes(valor) {
    if (!valor) return;
    const [desde, hasta] = valor.split('|');
    setFechas(desde, hasta);
  }
</script>

<div class="alert alert-success">
  <strong>Total recaudado:</strong> <%= number_to_currency(@total, unit: "$", delimiter: ".", separator: ",", precision: 0) %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>RC</th>
        <th>Miembro</th>
        <th>Logia</th>
        <th>Monto Pagado</th>
        <th>Fecha Pago</th>
        <th>M&eacute;todo</th>
        <th>Estado</th>
      </tr>
    </thead>
    <tbody>
      <% @pagos.each do |pago| %>
        <tr>
          <td><%= pago.numero_rc %></td>
          <td><%= pago.cobro.miembro.nombre_completo %></td>
          <td><%= pago.cobro.miembro.logia.nombre %></td>
          <td><%= number_to_currency(pago.monto_pagado, unit: "$", delimiter: ".", separator: ",", precision: 0) %></td>
          <td><%= l(pago.fecha_pago, format: :short) rescue pago.fecha_pago %></td>
          <td><%= pago.metodo_pago.humanize %></td>
          <td><%= render "shared/estado_badge", estado: "pagado" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= paginate @pagos %>
