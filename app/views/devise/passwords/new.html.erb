<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card shadow">
      <div class="card-body p-4">
        <h3 class="card-title text-center mb-4">👁️ Los Magios</h3>
        <p class="text-center text-muted mb-4">Recuperar Contrase&ntilde;a</p>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "needs-validation" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="mb-3">
            <%= f.label :email, "Correo electr&oacute;nico".html_safe, class: "form-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "correo@ejemplo.com" %>
          </div>

          <div class="d-grid mb-3">
            <%= f.submit "Enviar instrucciones", class: "btn btn-primary" %>
          </div>
        <% end %>

        <div class="text-center">
          <%= link_to "Volver al inicio de sesi&oacute;n".html_safe, new_session_path(resource_name), class: "text-decoration-none" %>
        </div>
      </div>
    </div>
  </div>
</div>
