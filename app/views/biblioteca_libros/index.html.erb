<% content_for(:title, "Biblioteca") %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h4 class="mb-0 fw-bold"><i class="bi bi-book me-2"></i>Biblioteca</h4>
      <p class="text-muted small mb-0">Libros y recursos compartidos</p>
    </div>
    <% if controller.send(:puede_gestionar?) %>
      <%= link_to new_biblioteca_libro_path, class: "btn btn-primary btn-sm" do %>
        <i class="bi bi-plus-lg me-1"></i>Agregar Libro
      <% end %>
    <% end %>
  </div>

  <%# Buscador + filtro categoria %>
  <div class="row g-2 mb-4">
    <%= form_with url: biblioteca_libros_path, method: :get, local: true, class: "col-12 col-md-5" do |f| %>
      <div class="input-group">
        <%= f.search_field :q, value: params[:q], class: "form-control form-control-sm",
              placeholder: "Buscar por título, autor..." %>
        <% if params[:categoria].present? %>
          <%= f.hidden_field :categoria, value: params[:categoria] %>
        <% end %>
        <button class="btn btn-outline-secondary btn-sm" type="submit"><i class="bi bi-search"></i></button>
      </div>
    <% end %>
    <div class="col-12 col-md-7 d-flex gap-2 flex-wrap">
      <%= link_to "Todos", biblioteca_libros_path(q: params[:q]),
            class: "btn btn-sm #{@categoria_filtro.nil? ? 'btn-dark' : 'btn-outline-secondary'}" %>
      <% BibliotecaLibro::CATEGORIAS.each do |cat| %>
        <%= link_to cat, biblioteca_libros_path(q: params[:q], categoria: cat),
              class: "btn btn-sm #{@categoria_filtro == cat ? 'btn-dark' : 'btn-outline-secondary'}" %>
      <% end %>
    </div>
  </div>

  <% if @libros.empty? %>
    <div class="text-center text-muted py-5">
      <i class="bi bi-book display-4 opacity-25"></i>
      <p class="mt-3">No hay libros en la biblioteca todavía.</p>
    </div>
  <% else %>
    <div class="row g-3">
      <% @libros.each do |libro| %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <div class="d-flex align-items-start justify-content-between mb-2">
                <div class="flex-grow-1">
                  <h6 class="mb-0 fw-semibold">
                    <%= link_to libro.titulo, biblioteca_libro_path(libro),
                          class: "text-decoration-none text-dark stretched-link" %>
                  </h6>
                  <% if libro.autor.present? %>
                    <div class="text-muted small"><%= libro.autor %></div>
                  <% end %>
                </div>
                <% if libro.tiene_archivo? %>
                  <i class="bi bi-<%= libro.archivo.attached? ? 'paperclip' : 'link-45deg' %> text-muted ms-1"></i>
                <% end %>
              </div>
              <% if libro.descripcion.present? %>
                <p class="text-muted small mb-2" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
                  <%= libro.descripcion %>
                </p>
              <% end %>
              <%# Stars %>
              <div class="d-flex align-items-center gap-2">
                <% promedio = libro.promedio_calificacion %>
                <% 5.times do |i| %>
                  <i class="bi bi-star<%= i < promedio.to_i ? '-fill' : (i < promedio.ceil && promedio % 1 >= 0.5 ? '-half' : '') %> text-warning" style="font-size:.75rem;"></i>
                <% end %>
                <span class="text-muted" style="font-size:.72rem;"><%= promedio > 0 ? "#{promedio} (#{libro.total_calificaciones})" : "Sin calificaciones" %></span>
              </div>
              <% if libro.categoria.present? %>
                <span class="badge bg-light text-dark border mt-2" style="font-size:.7rem;"><%= libro.categoria %></span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
