<%= form_with model: mensaje, url: negocio_conversacion_mensajes_path(conversacion), class: "d-flex gap-2" do |f| %>
  <%= f.text_area :cuerpo, rows: 1, class: "form-control", placeholder: "Escribe un mensaje...", required: true, style: "resize: none;" %>
  <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i></button>
<% end %>
