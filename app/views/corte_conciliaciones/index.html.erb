<% content_for(:title, "Conciliación de Cortes — #{@logia.nombre}") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    <i class="bi bi-clipboard2-check me-2"></i>Conciliación de Cortes
    <small class="text-muted fs-6 ms-1"><%= @logia.nombre %></small>
  </h1>
  <%= link_to miembros_path, class: "btn btn-outline-secondary btn-sm" do %>
    <i class="bi bi-arrow-left me-1"></i>Volver a Miembros
  <% end %>
</div>

<%# ── Upload Form ─────────────────────────────────────────── %>
<div class="card mb-4 border-primary">
  <div class="card-header bg-primary text-white">
    <h5 class="mb-0"><i class="bi bi-upload me-2"></i>Nuevo Corte</h5>
  </div>
  <div class="card-body">
    <%= form_with url: corte_conciliaciones_path(logia_id: @logia.id),
                  method: :post, multipart: true, class: "row g-3 align-items-end" do |f| %>
      <div class="col-md-3">
        <label class="form-label fw-semibold">Fecha del corte</label>
        <%= date_field_tag "corte_conciliacion[fecha_corte]", nil, class: "form-control",
              placeholder: "Auto-detectada del Excel" %>
        <div class="form-text">Opcional para Excel (se lee del archivo)</div>
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Descripción</label>
        <%= text_field_tag "corte_conciliacion[descripcion]", nil,
              class: "form-control", placeholder: "Ej: Lista oficial Gran Oriente Marzo 2025" %>
      </div>

      <div class="col-md-3">
        <label class="form-label fw-semibold">Archivo <span class="text-danger">*</span></label>
        <input type="file" name="archivo" class="form-control" accept=".csv,.xlsx,.xls,.pdf,.txt" required>
        <div class="form-text">CSV, Excel o PDF</div>
      </div>

      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-play-circle me-1"></i>Procesar
        </button>
      </div>
    <% end %>
  </div>
</div>

<%# ── Historial ───────────────────────────────────────────── %>
<% if @cortes.any? %>
  <div class="card">
    <div class="card-header">
      <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Historial de cortes</h5>
    </div>
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Fecha corte</th>
            <th>Descripción</th>
            <th>Formato</th>
            <th class="text-center">En archivo</th>
            <th class="text-center">En sistema</th>
            <th class="text-center">Coinciden</th>
            <th class="text-center">Sin match</th>
            <th class="text-center">Solo sistema</th>
            <th>Estado</th>
            <th>Cargado por</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @cortes.each do |c| %>
            <tr>
              <td><strong><%= l(c.fecha_corte, format: :long) %></strong></td>
              <td><%= c.descripcion.presence || "—" %></td>
              <td><span class="badge bg-light text-dark border"><%= c.formato_archivo&.upcase || "—" %></span></td>
              <td class="text-center"><%= c.total_archivo %></td>
              <td class="text-center"><%= c.total_sistema %></td>
              <td class="text-center text-success fw-semibold"><%= c.coincidentes.size %></td>
              <td class="text-center <%= c.sin_match.any? ? 'text-danger fw-semibold' : '' %>">
                <%= c.sin_match.size %>
              </td>
              <td class="text-center <%= c.solo_en_sistema.any? ? 'text-warning fw-semibold' : '' %>">
                <%= c.solo_en_sistema.size %>
              </td>
              <td>
                <span class="badge bg-<%= c.estado_badge_color %>"><%= c.estado_label %></span>
              </td>
              <td><small class="text-muted"><%= c.creado_por.nombre_completo %></small></td>
              <td class="text-end">
                <%= link_to corte_conciliacion_path(c, logia_id: @logia.id),
                      class: "btn btn-sm btn-outline-primary me-1" do %>
                  <i class="bi bi-eye"></i>
                <% end %>
                <% if policy(c).destroy? %>
                  <%= button_to corte_conciliacion_path(c, logia_id: @logia.id),
                        method: :delete,
                        class: "btn btn-sm btn-outline-danger",
                        form: { data: { turbo_confirm: "¿Eliminar este corte?" } } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <%= paginate @cortes %>
<% else %>
  <div class="alert alert-info">
    <i class="bi bi-info-circle me-2"></i>Aún no hay cortes registrados. Sube el primer archivo.
  </div>
<% end %>
