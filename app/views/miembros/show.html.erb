<% content_for(:title, @miembro.nombre_completo) %>

<div class="mb-4">
  <div class="card">
    <div class="card-header">
      <h1 class="card-title h3 mb-0"><%= @miembro.nombre_completo %></h1>
    </div>
    <div class="card-body">
      <dl class="row mb-0">
        <dt class="col-sm-3">Nombre completo</dt>
        <dd class="col-sm-9"><%= @miembro.nombre_completo %></dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9"><%= @miembro.email %></dd>

        <dt class="col-sm-3">Numero de miembro</dt>
        <dd class="col-sm-9"><%= @miembro.numero_miembro %></dd>

        <dt class="col-sm-3">Cedula</dt>
        <dd class="col-sm-9"><%= @miembro.cedula %></dd>

        <dt class="col-sm-3">Grado</dt>
        <dd class="col-sm-9"><%= @miembro.grado %></dd>

        <dt class="col-sm-3">Fecha de ingreso</dt>
        <dd class="col-sm-9">
          <% if @miembro.fecha_ingreso.present? %>
            <%= l(@miembro.fecha_ingreso, format: :long) rescue @miembro.fecha_ingreso %>
          <% else %>
            <span class="text-muted">No registrada</span>
          <% end %>
        </dd>

        <dt class="col-sm-3">Logia</dt>
        <dd class="col-sm-9"><%= @miembro.logia.nombre %></dd>

        <dt class="col-sm-3">Estado</dt>
        <dd class="col-sm-9">
          <%= render "shared/estado_badge", estado: @miembro.estado %>
          <% if !@miembro.activo? && @miembro.estado_desde.present? %>
            <small class="text-muted ms-2">
              desde <%= l(@miembro.estado_desde, format: :short) rescue @miembro.estado_desde %>
              <% if @miembro.estado_hasta.present? %>
                hasta <%= l(@miembro.estado_hasta, format: :short) rescue @miembro.estado_hasta %>
              <% else %>
                &mdash; indefinido
              <% end %>
            </small>
          <% end %>
          <% if @miembro.estado_motivo.present? %>
            <br><small class="text-muted"><i class="bi bi-chat-text me-1"></i><%= @miembro.estado_motivo %></small>
          <% end %>
        </dd>
      </dl>
    </div>
    <div class="card-footer d-flex gap-2">
      <%= link_to "Volver", miembros_path, class: "btn btn-outline-secondary" %>
      <% if policy(@miembro).update? %>
        <%= link_to "Editar", edit_miembro_path(@miembro), class: "btn btn-outline-primary" %>
        <% if @miembro.activo? %>
          <%= link_to cambiar_estado_miembro_path(@miembro), class: "btn btn-warning" do %>
            <i class="bi bi-person-dash me-1"></i>Desactivar
          <% end %>
        <% else %>
          <%= link_to cambiar_estado_miembro_path(@miembro), class: "btn btn-success" do %>
            <i class="bi bi-person-check me-1"></i>Reactivar
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<%# ── Rol del Sistema ─────────────────────────────────────── %>
<% if policy(@miembro).update? %>
<div class="card mb-4">
  <div class="card-header d-flex align-items-center justify-content-between">
    <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Rol del Sistema</h5>
    <%
      rol_actual = @miembro.user.rol_ref
      es_admin   = rol_actual&.codigo == "admin_logia"
    %>
    <span class="badge fs-6 <%= es_admin ? 'bg-primary' : 'bg-secondary' %>">
      <%= rol_actual&.nombre || "Sin rol" %>
    </span>
  </div>
  <div class="card-body">
    <% if @miembro.activo? %>
      <p class="text-muted small mb-3">
        <i class="bi bi-info-circle me-1"></i>
        Solo los miembros <strong>activos</strong> pueden tener el rol de Administrador.
      </p>
      <div class="d-flex gap-2 flex-wrap">
        <% [ ["admin_logia", "Administrador", "btn-primary", "bi-shield-fill-check"],
             ["miembro",     "Miembro",        "btn-secondary", "bi-person-fill"] ].each do |codigo, label, btn_class, icon| %>
          <%= button_to cambiar_rol_miembro_path(@miembro), method: :patch,
                class: "btn #{es_admin && codigo == 'admin_logia' || !es_admin && codigo == 'miembro' ? btn_class : 'btn-outline-' + btn_class.sub('btn-', '')} #{(es_admin && codigo == 'admin_logia') || (!es_admin && codigo == 'miembro') ? 'active' : ''}",
                params: { rol_codigo: codigo },
                form: { data: { turbo_confirm: "¿Cambiar el rol a «#{label}»?" } } do %>
            <i class="bi <%= icon %> me-1"></i><%= label %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-warning mb-0 py-2">
        <i class="bi bi-lock me-2"></i>
        El miembro no está activo. Para asignar el rol de Administrador debe estar <strong>Activo</strong>.
        <span class="ms-2 badge bg-secondary"><%= @miembro.estado_label %></span>
      </div>
    <% end %>
  </div>
</div>
<% end %>

<%# ── Cargos / Dignidades ─────────────────────────────────── %>
<div id="cargos" class="card mb-4">
  <div class="card-header d-flex align-items-center justify-content-between">
    <h5 class="mb-0"><i class="bi bi-award me-2"></i>Cargos y Dignidades</h5>
    <% if policy(@miembro).update? %>
      <% if @miembro.activo? %>
        <button class="btn btn-sm btn-outline-primary" type="button"
                data-bs-toggle="collapse" data-bs-target="#form-nuevo-cargo" aria-expanded="false">
          <i class="bi bi-plus-circle me-1"></i>Asignar cargo
        </button>
      <% else %>
        <span class="badge bg-warning text-dark">
          <i class="bi bi-lock me-1"></i>Solo miembros activos
        </span>
      <% end %>
    <% end %>
  </div>

  <% if policy(@miembro).update? && @miembro.activo? %>
    <div class="collapse" id="form-nuevo-cargo">
      <div class="card-body border-bottom bg-light">
        <%= form_with url: miembro_cargos_path(@miembro), method: :post, class: "row g-2 align-items-end" do |f| %>
          <div class="col-md-4">
            <label class="form-label small fw-semibold mb-1">Cargo</label>
            <%
              cargos_logia = Cargo.where(logia_id: @miembro.logia_id).activos.ordenados
            %>
            <select name="miembro_cargo[cargo_id]" class="form-select form-select-sm" id="select-cargo">
              <option value="">— Seleccionar cargo existente —</option>
              <% cargos_logia.each do |c| %>
                <option value="<%= c.id %>"><%= c.nombre %></option>
              <% end %>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label small fw-semibold mb-1">O nuevo cargo</label>
            <input type="text" name="miembro_cargo[nuevo_cargo_nombre]" class="form-control form-control-sm"
                   placeholder="Ej: Limosnero">
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-semibold mb-1">Desde</label>
            <input type="date" name="miembro_cargo[desde]" class="form-control form-control-sm"
                   value="<%= Date.current %>" required>
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-semibold mb-1">Hasta <span class="text-muted">(opcional)</span></label>
            <input type="date" name="miembro_cargo[hasta]" class="form-control form-control-sm">
          </div>
          <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-primary btn-sm">
              <i class="bi bi-check-lg"></i>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="card-body p-0">
    <%
      cargos_vigentes   = @miembro.miembro_cargos.vigentes.includes(:cargo).cronologicos
      cargos_historicos = @miembro.miembro_cargos.historicos.includes(:cargo).cronologicos
    %>
    <% if cargos_vigentes.any? || cargos_historicos.any? %>
      <table class="table table-sm mb-0">
        <thead class="table-light">
          <tr>
            <th>Cargo</th>
            <th>Desde</th>
            <th>Hasta</th>
            <th>Estado</th>
            <% if policy(@miembro).update? %><th></th><% end %>
          </tr>
        </thead>
        <tbody>
          <% cargos_vigentes.each do |mc| %>
            <tr>
              <td class="fw-semibold"><%= mc.cargo.nombre %></td>
              <td><%= mc.desde&.strftime("%d/%m/%Y") %></td>
              <td class="text-muted">—</td>
              <td><span class="badge bg-success">Vigente</span></td>
              <% if policy(@miembro).update? %>
                <td class="text-end">
                  <%= form_with url: miembro_cargo_path(@miembro, mc), method: :patch, class: "d-inline" do |f| %>
                    <input type="hidden" name="miembro_cargo[hasta]" value="<%= Date.current %>">
                    <button type="submit" class="btn btn-outline-warning btn-sm"
                            title="Finalizar cargo hoy"
                            data-turbo-confirm="¿Finalizar el cargo «<%= mc.cargo.nombre %>» hoy?">
                      <i class="bi bi-calendar-x"></i>
                    </button>
                  <% end %>
                  <%= button_to miembro_cargo_path(@miembro, mc), method: :delete,
                        class: "btn btn-outline-danger btn-sm",
                        form: { data: { turbo_confirm: "¿Eliminar este cargo?" } } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
          <% cargos_historicos.each do |mc| %>
            <tr class="text-muted">
              <td><%= mc.cargo.nombre %></td>
              <td><%= mc.desde&.strftime("%d/%m/%Y") %></td>
              <td><%= mc.hasta&.strftime("%d/%m/%Y") %></td>
              <td><span class="badge bg-secondary">Finalizado</span></td>
              <% if policy(@miembro).update? %>
                <td class="text-end">
                  <%= button_to miembro_cargo_path(@miembro, mc), method: :delete,
                        class: "btn btn-outline-danger btn-sm",
                        form: { data: { turbo_confirm: "¿Eliminar este cargo del historial?" } } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted small p-3 mb-0"><i class="bi bi-info-circle me-1"></i>No hay cargos asignados aún.</p>
    <% end %>
  </div>
</div>

<% if @miembro.cobros.any? %>
  <h2 class="mb-3">Cobros recientes</h2>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>Periodo</th>
          <th>Monto</th>
          <th>Estado</th>
          <th>Fecha</th>
        </tr>
      </thead>
      <tbody>
        <% @miembro.cobros.recientes.limit(10).each do |cobro| %>
          <tr>
            <td><%= cobro.periodo_cobro.nombre if cobro.periodo_cobro %></td>
            <td><%= number_to_currency(cobro.monto, unit: "$", precision: 0) %></td>
            <td><%= render "shared/estado_badge", estado: cobro.estado %></td>
            <td><%= l(cobro.created_at, format: :short) rescue cobro.created_at.strftime("%d/%m/%Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
