<% content_for(:title, "Mis conversaciones") %>

<div class="container py-4" style="max-width: 900px;">
  <h4 class="fw-bold mb-3"><i class="bi bi-chat-left-text me-2"></i>Mis conversaciones</h4>

  <% if @conversaciones.empty? %>
    <div class="text-center text-muted py-5 bg-white rounded shadow-sm">
      <i class="bi bi-chat display-3 opacity-25"></i>
      <p class="mt-3">No tienes conversaciones aún.</p>
      <%= link_to "Ir al marketplace", negocios_path, class: "btn btn-primary btn-sm" %>
    </div>
  <% else %>
    <div class="list-group shadow-sm">
      <% @conversaciones.each do |conv| %>
        <% otro = conv.otro_usuario(current_user) %>
        <% no_leidos = conv.no_leidos_para(current_user) %>
        <%= link_to negocio_conversacion_path(conv), class: "list-group-item list-group-item-action d-flex gap-3 align-items-center" do %>
          <% img = conv.negocio_anuncio.imagen_principal %>
          <% if img %>
            <img src="<%= rails_blob_path(img) %>" style="width:56px;height:56px;object-fit:cover;border-radius:6px;">
          <% else %>
            <div class="bg-light d-flex align-items-center justify-content-center text-muted" style="width:56px;height:56px;border-radius:6px;">
              <i class="bi bi-image"></i>
            </div>
          <% end %>
          <div class="flex-grow-1 min-w-0">
            <div class="d-flex justify-content-between align-items-baseline">
              <strong class="text-truncate"><%= conv.negocio_anuncio.titulo %></strong>
              <small class="text-muted"><%= time_ago_in_words(conv.ultimo_mensaje_at || conv.created_at) %></small>
            </div>
            <div class="small text-muted text-truncate">
              Con <%= otro.nombre_completo %>
              <% ultimo = conv.mensajes.last %>
              <% if ultimo %> · <%= truncate(ultimo.cuerpo, length: 60) %><% end %>
            </div>
          </div>
          <% if no_leidos.positive? %>
            <span class="badge bg-danger rounded-pill"><%= no_leidos %></span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
