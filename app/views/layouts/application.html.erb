<!DOCTYPE html>
<html lang="es">
  <head>
    <%# Branding visual: nil en contexto de plataforma (sin subdominio/usuario/preview) %>
    <% _logia = display_logia %>
    <title><%= content_for(:title) || (_logia ? "#{_logia.icono_display} #{_logia.nombre_display}" : "COMUNIA") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="<%= (_logia&.nombre_display || 'COMUNIA').to_s[0,14] %>">
    <meta name="theme-color" content="<%= _logia&.color_display || '#1B2A4A' %>">
    <meta name="format-detection" content="telephone=no">
    <meta name="vapid-public-key" content="<%= Rails.application.config.x.vapid[:public_key] %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Inject tenant primary color as CSS variable %>
    <% if (logia_color = _logia&.color_display) %>
      <style>
        :root { --bs-primary: <%= logia_color %>; --tenant-primary: <%= logia_color %>; }
        .btn-primary, .navbar-main { background-color: <%= logia_color %> !important; border-color: <%= logia_color %> !important; }
        .navbar-main .nav-link:hover, .navbar-main .nav-link.active { color: rgba(255,255,255,0.9) !important; }
      </style>
    <% end %>

    <%# PWA manifest dinámico (con branding del tenant activo). %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <% if user_signed_in? %>
      <nav class="navbar navbar-expand-lg navbar-main">
        <div class="container-fluid px-4">
          <%= link_to root_path, class: "navbar-brand fw-bold" do %>
            <% if _logia %>
              <% if _logia.logo.attached? %>
                <%= image_tag _logia.logo, height: 28, class: "me-2", alt: _logia.nombre_display %>
              <% else %>
                <%= _logia.icono_display %>
              <% end %>
              <%= _logia.nombre_display %>
            <% else %>
              <i class="bi bi-grid-3x3-gap me-1"></i>COMUNIA
            <% end %>
          <% end %>

          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <% if platform_admin_context? %>
                <%# ── Navbar COMUNIA: solo gestión de plataforma ── %>
                <li class="nav-item">
                  <%= link_to tenants_path, class: "nav-link #{'active' if request.path.start_with?('/tenants')}" do %>
                    <i class="bi bi-grid-3x3-gap"></i> Tenants
                  <% end %>
                </li>
                <% if current_user.tiene_permiso?("roles", "index") %>
                  <li class="nav-item">
                    <%= link_to roles_path, class: "nav-link #{'active' if request.path.start_with?('/roles')}" do %>
                      <i class="bi bi-shield-lock"></i> Roles
                    <% end %>
                  </li>
                <% end %>
              <% else %>
                <%# ── Navbar tenant: módulos operativos ── %>
                <li class="nav-item">
                  <%= link_to dashboard_path, class: "nav-link #{'active' if current_page?(dashboard_path) || current_page?(root_path)}" do %>
                    <i class="bi bi-speedometer2"></i> Dashboard
                  <% end %>
                </li>

                <% if current_user.tiene_permiso?("logias", "index") %>
                  <li class="nav-item">
                    <%= link_to logia_path(current_logia), class: "nav-link #{'active' if request.path.start_with?('/logias')}" do %>
                      <i class="bi bi-building"></i> Mi <%= current_logia.t_logia %>
                    <% end %>
                  </li>
                <% end %>

                <% if current_user.tiene_permiso?("miembros", "index") %>
                  <li class="nav-item">
                    <%= link_to miembros_path, class: "nav-link #{'active' if request.path.start_with?('/miembros')}" do %>
                      <i class="bi bi-people"></i> <%= current_logia.t_miembro.pluralize %>
                    <% end %>
                  </li>
                <% end %>

                <%
                  _puede_cobros    = current_user.tiene_permiso?("cobros", "index") || current_user.miembro.present?
                  _puede_periodos  = current_user.tiene_permiso?("periodos", "index")
                  _puede_conceptos = current_user.tiene_permiso?("logias", "gestionar_conceptos") && current_user.scope_propia_logia? && current_user.logia.present?
                  _puede_cartera   = current_user.tiene_permiso?("reportes", "cartera")
                  _puede_recaud    = current_user.tiene_permiso?("reportes", "recaudacion")
                  _puede_morosos   = current_user.tiene_permiso?("reportes", "morosos")
                  _tiene_tesoreria = _puede_cobros || _puede_periodos || _puede_conceptos || _puede_cartera || _puede_recaud || _puede_morosos
                  _tesoreria_activa = ["/cobros", "/periodos", "/conceptos", "/reportes"].any? { |p| request.path.start_with?(p) }
                %>
                <% if _tiene_tesoreria %>
                  <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle <%= 'active' if _tesoreria_activa %>" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                      <i class="bi bi-bank2"></i> Tesorer&iacute;a
                    </a>
                    <ul class="dropdown-menu">
                      <% if _puede_cobros %>
                        <li><%= link_to cobros_path, class: "dropdown-item #{'active' if request.path.start_with?('/cobros')}" do %><i class="bi bi-receipt me-2"></i><%= current_user.tiene_permiso?("cobros", "index") ? current_logia.t_cobro.pluralize : "Mis #{current_logia.t_cobro.pluralize}" %><% end %></li>
                      <% end %>
                      <% if _puede_periodos %>
                        <li><%= link_to periodo_cobros_path, class: "dropdown-item #{'active' if request.path.start_with?('/periodos')}" do %><i class="bi bi-calendar-check me-2"></i>Periodos<% end %></li>
                      <% end %>
                      <% if _puede_conceptos %>
                        <li><%= link_to logia_conceptos_cobro_path(current_user.logia), class: "dropdown-item #{'active' if request.path.include?('/conceptos')}" do %><i class="bi bi-list-columns-reverse me-2"></i>Cuota Mensual<% end %></li>
                      <% end %>
                      <% if (_puede_cartera || _puede_recaud || _puede_morosos) %>
                        <li><hr class="dropdown-divider"></li>
                        <li><h6 class="dropdown-header"><i class="bi bi-graph-up me-1"></i>Reportes</h6></li>
                        <% if _puede_cartera %>
                          <li><%= link_to cartera_reportes_path, class: "dropdown-item #{'active' if request.path == cartera_reportes_path}" do %><i class="bi bi-wallet2 me-2"></i>Cartera<% end %></li>
                        <% end %>
                        <% if _puede_recaud %>
                          <li><%= link_to recaudacion_reportes_path, class: "dropdown-item #{'active' if request.path == recaudacion_reportes_path}" do %><i class="bi bi-cash-stack me-2"></i>Recaudaci&oacute;n<% end %></li>
                        <% end %>
                        <% if _puede_morosos %>
                          <li><%= link_to morosos_reportes_path, class: "dropdown-item #{'active' if request.path == morosos_reportes_path}" do %><i class="bi bi-exclamation-triangle me-2"></i>Morosos<% end %></li>
                        <% end %>
                      <% end %>
                    </ul>
                  </li>
                <% end %>

                <%# ── Red Social ── %>
                <li class="nav-item dropdown">
                  <a class="nav-link dropdown-toggle <%= 'active' if request.path.start_with?('/chat') || request.path.start_with?('/calendario') || request.path.start_with?('/hospitalia/cumpleanos') %>"
                     href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-people-fill"></i> Red Social
                  </a>
                  <ul class="dropdown-menu">
                    <li><h6 class="dropdown-header" style="font-size:.68rem;letter-spacing:.06em;">COMUNICACIÓN</h6></li>
                    <li>
                      <%= link_to chat_path, class: "dropdown-item #{'active' if request.path.start_with?('/chat')}" do %>
                        <i class="bi bi-chat-dots me-2"></i>Chat
                      <% end %>
                    </li>
                    <li><hr class="dropdown-divider my-1"></li>
                    <li><h6 class="dropdown-header" style="font-size:.68rem;letter-spacing:.06em;">EVENTOS</h6></li>
                    <li>
                      <%= link_to calendario_index_path, class: "dropdown-item #{'active' if request.path.start_with?('/calendario')}" do %>
                        <i class="bi bi-calendar3 me-2"></i>Calendario
                      <% end %>
                    </li>
                    <li>
                      <%= link_to hospitalia_cumpleanos_path, class: "dropdown-item #{'active' if request.path.start_with?('/hospitalia/cumpleanos')}" do %>
                        <i class="bi bi-balloon-heart me-2 text-warning"></i>Cumpleaños
                      <% end %>
                    </li>
                  </ul>
                </li>

                <%# ── Biblioteca ── %>
                <li class="nav-item dropdown">
                  <a class="nav-link dropdown-toggle <%= 'active' if request.path.start_with?('/biblioteca') %>"
                     href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-book-half"></i> Biblioteca
                  </a>
                  <ul class="dropdown-menu">
                    <li>
                      <%= link_to biblioteca_planchas_path, class: "dropdown-item #{'active' if request.path.start_with?('/biblioteca/planchas')}" do %>
                        <i class="bi bi-file-earmark-text me-2"></i>Planchas
                      <% end %>
                    </li>
                    <li>
                      <%= link_to biblioteca_libros_path, class: "dropdown-item #{'active' if request.path.start_with?('/biblioteca/libros')}" do %>
                        <i class="bi bi-book me-2"></i>Libros
                      <% end %>
                    </li>
                  </ul>
                </li>

                <%# ── Hospitalia ── %>
                <li class="nav-item dropdown">
                  <a class="nav-link dropdown-toggle <%= 'active' if request.path.start_with?('/hospitalia') %>"
                     href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-heart-pulse"></i> Hospitalia
                  </a>
                  <ul class="dropdown-menu">
                    <li>
                      <%= link_to hospitalia_path, class: "dropdown-item #{'active' if request.path == '/hospitalia'}" do %>
                        <i class="bi bi-speedometer2 me-2"></i>Resumen
                      <% end %>
                    </li>
                    <li>
                      <%= link_to hospitalia_recaudos_path, class: "dropdown-item #{'active' if request.path.start_with?('/hospitalia/recaudos')}" do %>
                        <i class="bi bi-arrow-down-circle me-2 text-success"></i>Recaudos
                      <% end %>
                    </li>
                    <li>
                      <%= link_to hospitalia_gastos_path, class: "dropdown-item #{'active' if request.path.start_with?('/hospitalia/gastos')}" do %>
                        <i class="bi bi-arrow-up-circle me-2 text-danger"></i>Gastos
                      <% end %>
                    </li>
                    <li><hr class="dropdown-divider my-1"></li>
                    <li>
                      <%= link_to hospitalia_cumpleanos_path, class: "dropdown-item #{'active' if request.path.start_with?('/hospitalia/cumpleanos')}" do %>
                        <i class="bi bi-balloon-heart me-2 text-warning"></i>Cumpleaños
                      <% end %>
                    </li>
                  </ul>
                </li>

                <%# ── Negocios ── %>
                <li class="nav-item">
                  <%= link_to negocios_path, class: "nav-link #{'active' if request.path.start_with?('/negocios')}" do %>
                    <i class="bi bi-briefcase"></i> Negocios
                  <% end %>
                </li>

                <% if current_user.tiene_permiso?("roles", "index") %>
                  <li class="nav-item">
                    <%= link_to roles_path, class: "nav-link #{'active' if request.path.start_with?('/roles')}" do %>
                      <i class="bi bi-shield-lock"></i> Roles
                    <% end %>
                  </li>
                <% end %>
              <% end %>
            </ul>

            <ul class="navbar-nav align-items-lg-center">
              <%# ── Notification bell ── %>
              <li class="nav-item me-2 dropdown" data-controller="notifications">
                <%= turbo_stream_from "notificaciones_#{current_user.id}" %>
                <a href="#" class="nav-link position-relative" role="button"
                   data-action="click->notifications#togglePanel"
                   style="padding:.4rem .5rem;">
                  <i class="bi bi-bell" style="font-size:1.1rem;"></i>
                  <% badge_count = current_user.notificaciones.no_leidas.count %>
                  <span id="notification-badge"
                    <% if badge_count > 0 %>
                        class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                        style="font-size:0.6rem;"
                    <% end %>
                  ><%= badge_count > 0 ? (badge_count > 99 ? '99+' : badge_count) : '' %></span>
                </a>
                <div class="dropdown-menu dropdown-menu-end p-0 shadow"
                     style="width:340px;max-height:420px;overflow:hidden;"
                     data-notifications-target="panel">
                  <turbo-frame id="notificaciones-lista" data-notifications-target="frame" loading="lazy">
                    <div class="text-center py-4 text-muted small">
                      <div class="spinner-border spinner-border-sm me-1"></div> Cargando...
                    </div>
                  </turbo-frame>
                </div>
              </li>

              <li class="nav-item me-2 d-none d-lg-block">
                <span class="badge rounded-pill <%= current_user.rol_ref&.es_super_admin? ? 'bg-warning text-dark' : (current_user.tiene_permiso?('miembros', 'index') ? 'bg-info' : 'bg-light text-dark') %>">
                  <%= current_user.nombre_rol %>
                </span>
              </li>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="bi bi-person-circle"></i> <%= current_user.nombre_corto %>
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><span class="dropdown-item-text text-muted small"><%= current_user.email %></span></li>
                  <li>
                    <span class="dropdown-item-text d-lg-none">
                      <span class="badge rounded-pill <%= current_user.rol_ref&.es_super_admin? ? 'bg-warning text-dark' : (current_user.tiene_permiso?('miembros', 'index') ? 'bg-info' : 'bg-light text-dark') %>">
                        <%= current_user.nombre_rol %>
                      </span>
                    </span>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" do %>
                      <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesi&oacute;n
                    <% end %>
                  </li>
                </ul>
              </li>
            </ul>
          </div>
        </div>
      </nav>

      <%# ── Banner de vista previa ──────────────────────────── %>
      <% if previewing_tenant? %>
        <div class="d-flex align-items-center justify-content-between px-4 py-2"
             style="background: #ff6b00; color: #fff; font-size: 0.85rem;">
          <span>
            <i class="bi bi-eye-fill me-2"></i>
            <strong>Vista previa:</strong> estás viendo el tenant
            <strong><%= current_logia.nombre_display %></strong>
            — los datos mostrados son reales de este tenant.
          </span>
          <%= button_to exit_preview_tenants_path, method: :delete,
                class: "btn btn-sm btn-light text-dark fw-semibold",
                style: "font-size:0.8rem" do %>
            <i class="bi bi-x-circle me-1"></i>Salir de vista previa
          <% end %>
        </div>
      <% end %>

      <main class="flex-grow-1 py-4">
        <div class="container-fluid px-4">
          <%= render "shared/flash" %>
          <div class="content-animate">
            <%= yield %>
          </div>
        </div>
      </main>

      <footer class="footer mt-auto py-3 border-top bg-white">
        <div class="container-fluid px-4 text-center text-muted small">
          <% if _logia %>
            <%= _logia.icono_display %> <%= _logia.nombre_display %> &copy; <%= Date.current.year %>
            <% if _logia.lema_display.present? %>
              &mdash; <%= _logia.lema_display %>
            <% end %>
          <% else %>
            <i class="bi bi-grid-3x3-gap me-1"></i>COMUNIA &copy; <%= Date.current.year %>
          <% end %>
        </div>
      </footer>

    <% else %>
      <%= render "shared/flash" %>
      <%= yield %>
    <% end %>

    <%# ── PWA: registrar service worker para instalación móvil ── %>
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("<%= pwa_service_worker_path %>", { scope: "<%= request.script_name.presence || '/' %>/" }).catch(function (e) {
            console.warn("SW registration failed", e);
          });
        });
      }
    </script>
  </body>
</html>
